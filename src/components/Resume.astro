---
import resume from "../data/resume.json";
import ResumeItemCard from "./ResumeItemCard.astro";

type ResumeItem = {
  title: string;
  meta?: string;
  category?: string;
  startDate?: string;
  endDate?: string;
  github?: string;
  intro?: string;
  details?: string;
  skills?: string[];
  note?: string;
  references?: { label: string; url: string }[];
};

type ResumeSection = {
  label: string;
  description?: string;
  items: ResumeItem[];
};

const sections = Object.entries(resume) as [string, ResumeSection][];
const workItems = resume.work?.items ?? [];
const projectItems = resume.projects?.items ?? [];
const projectGroups = Object.entries(
  projectItems.reduce<Record<string, ResumeItem[]>>((groups, item) => {
    const category = item.category ?? "Other";
    groups[category] ??= [];
    groups[category].push(item);
    return groups;
  }, {}),
);
const totalProjects = projectItems.length;
const totalExperienceYears = workItems[0]?.startDate
  ? Math.max(
      1,
      Math.floor(
        (Date.now() - new Date(workItems[0].startDate).getTime()) /
          (1000 * 60 * 60 * 24 * 365),
      ),
    )
  : 0;
const primaryLanguages = ["Java", "Golang"];
const keyAreas = ["Payments", "Distributed Systems", "Reliability"];

const sectionIcon = (sectionKey: string) => {
  if (sectionKey === "work") return "->";
  if (sectionKey === "projects") return "<>";
  return "[]";
};
---

<section class="resume-page container">
  <header class="resume-header">
    <span class="prompt">~/</span>
    <span>resume</span>
  </header>

  <div class="overview-grid reveal">
    <div class="resume-hero">
      <div class="resume-copy">
        <p class="eyebrow">Software Engineer</p>
        <h1 class="resume-title">Resume</h1>
        <p class="resume-lead">
          Building transaction-heavy systems, developer-facing tools, and practical
          projects with an emphasis on reliability, security, and operational clarity.
        </p>
        <div class="core-stack">
          <span class="stack-label">Primary languages</span>
          <div class="stack-list">
            {primaryLanguages.map((language) => (
              <span class="stack-pill">{language}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

  <div class="summary-strip reveal-delay-1">
    <article class="summary-card">
      <span class="summary-value">{totalExperienceYears}+</span>
      <span class="summary-label">Years in production engineering</span>
    </article>
    <article class="summary-card">
      <span class="summary-value">{totalProjects}</span>
      <span class="summary-label">Selected projects</span>
    </article>
    <article class="summary-card">
      <span class="summary-value">Core</span>
      <span class="summary-label">{keyAreas.join(" · ")}</span>
    </article>
  </div>

  <div class="resume-callout reveal-delay-1">
    <p class="callout-copy">
      Interested in how I build? Check my
      <a href="https://github.com/AbiXnash" target="_blank" rel="noreferrer">GitHub profile</a>
      or
      <a href="https://github.com/AbiXnash/theabxfolio" target="_blank" rel="noreferrer">see the source</a>
      for this site.
    </p>
  </div>

  <nav class="section-nav reveal-delay-1" aria-label="Resume sections">
    {sections.map(([sectionKey, section]) => (
      <a class="section-nav-link" href={`#${sectionKey}`}>
        <span class="section-nav-icon">{sectionIcon(sectionKey)}</span>
        <span>{section.label}</span>
      </a>
    ))}
  </nav>
  </div>

  <div class="resume-main">
    {sections.map(([sectionKey, section]) => (
      <section class="resume-section" id={sectionKey}>
        <div class="section-shell">
          <div class="section-header">
            <div class="section-label-row">
              <h2 class="section-heading">
                <span class="heading-icon">{sectionIcon(sectionKey)}</span>
                {section.label}
              </h2>
              <span class="section-count">{section.items.length}</span>
            </div>
            {section.description && <p class="section-description">{section.description}</p>}
          </div>

          <div class="section-content">
            {section.items.length === 0 ? (
              <div class="empty-state">Nothing here yet.</div>
            ) : sectionKey === "projects" ? (
              <div class="project-groups">
                {projectGroups.map(([groupName, items]) => (
                  <div class="project-group">
                    <div class="project-group-header">
                      <h3 class="project-group-title">{groupName}</h3>
                      <span class="project-group-count">{items.length}</span>
                    </div>
                    <div class="item-list dense-grid">
                      {items.map((item) => (
                        <ResumeItemCard item={item} sectionKey={sectionKey} />
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div class={`item-list ${sectionKey === "work" ? "" : "dense-grid"}`.trim()}>
                {section.items.map((item) => (
                  <ResumeItemCard item={item} sectionKey={sectionKey} />
                ))}
              </div>
            )}
          </div>
        </div>
      </section>
    ))}
  </div>
</section>

<style>
  .resume-page {
    padding: 3rem 0;
  }

  @media (min-width: 768px) {
    .resume-page {
      padding: 4rem 0 3rem;
    }
  }

  .resume-header {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .prompt {
    color: var(--accent);
  }

  .resume-title {
    font-size: clamp(1.75rem, 6vw, 3rem);
    font-weight: 700;
    margin-top: 0.25rem;
    margin-bottom: 0.75rem;
  }

  @media (min-width: 768px) {
    .resume-title {
      margin-bottom: 1rem;
    }
  }

  .overview-grid {
    display: grid;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .resume-hero {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 22px;
    background:
      radial-gradient(circle at top right, rgba(255, 107, 53, 0.12), transparent 30%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01));
  }

  .eyebrow {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .resume-lead {
    max-width: 60ch;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .core-stack {
    margin-top: 1.5rem;
    display: grid;
    gap: 0.6rem;
  }

  .stack-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
  }

  .stack-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .stack-pill {
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(255, 107, 53, 0.18), rgba(255, 107, 53, 0.08));
    border: 1px solid rgba(255, 107, 53, 0.28);
    color: var(--text);
    font-weight: 600;
    box-shadow: 0 10px 24px rgba(255, 107, 53, 0.08);
  }

  .summary-strip {
    display: grid;
    gap: 0.875rem;
    margin-bottom: 1rem;
  }

  .summary-card {
    padding: 0.95rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.025);
  }

  .summary-value {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
  }

  .summary-label {
    display: block;
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .resume-callout {
    padding: 1rem 1.05rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    background:
      linear-gradient(135deg, rgba(255, 107, 53, 0.1), rgba(255, 255, 255, 0.02)),
      rgba(255, 255, 255, 0.01);
    margin-bottom: 1rem;
  }

  .callout-copy {
    max-width: 62ch;
    color: var(--text);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .callout-copy a {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin: 0 0.15rem;
    text-decoration: none;
    color: var(--accent);
    font-weight: 600;
    border-bottom: 1px solid rgba(255, 107, 53, 0.38);
    transition:
      color 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .callout-copy a:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  .section-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-bottom: 1.75rem;
  }

  .section-nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 0.85rem;
    border-radius: 12px;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background 160ms ease;
  }

  .section-nav-link:hover {
    color: var(--text);
    border-color: rgba(255, 107, 53, 0.22);
    background: rgba(255, 107, 53, 0.06);
  }

  .section-nav-icon {
    color: var(--accent);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
  }

  .resume-main {
    display: grid;
    gap: 1.15rem;
  }

  @media (min-width: 900px) {
    .overview-grid {
      grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.9fr);
      align-items: start;
    }

    .summary-strip {
      grid-template-columns: 1fr;
    }
  }

  .resume-section {
    scroll-margin-top: 6rem;
  }

  .section-shell {
    display: grid;
    gap: 1.25rem;
    padding: 1.2rem;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0.01)),
      rgba(12, 12, 12, 0.3);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 20px 40px rgba(0, 0, 0, 0.14);
  }

  .project-groups {
    display: grid;
    gap: 1.1rem;
  }

  .project-group {
    display: grid;
    gap: 0.9rem;
  }

  .project-group-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    background:
      linear-gradient(135deg, rgba(255, 107, 53, 0.08), rgba(255, 255, 255, 0.02));
  }

  .project-group-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  .project-group-count {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .section-header {
    display: grid;
    gap: 0.8rem;
  }

  .section-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .section-count {
    flex-shrink: 0;
    min-width: 2rem;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-muted);
    text-align: center;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
  }

  .section-description {
    max-width: 62ch;
    color: var(--text-muted);
    line-height: 1.6;
    font-size: 0.86rem;
  }

  @media (min-width: 640px) {
    .section-heading {
      font-size: 0.9375rem;
      margin-bottom: 0.65rem;
    }
  }

  .heading-icon {
    color: var(--accent);
    font-size: 1rem;
  }

  .item-list {
    display: grid;
    gap: 1rem;
  }

  .empty-state {
    color: var(--text-dim);
    padding: 2rem;
    text-align: center;
    border: 1px dashed var(--border);
    border-radius: 12px;
    font-size: 0.875rem;
  }

  @media (max-width: 560px) {
    .resume-hero,
    .resume-summary,
    .section-shell {
      padding: 1rem;
      border-radius: 18px;
    }

    .project-group-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (min-width: 900px) {
    .section-shell {
      grid-template-columns: minmax(220px, 0.46fr) minmax(0, 1fr);
      align-items: start;
    }

    .section-header {
      position: sticky;
      top: 5rem;
    }
  }
</style>
