---
import resume from "../data/resume.json";

const formatDate = (date) =>
  date.toLocaleDateString("en-US", {
    month: "short",
    year: "numeric",
  });

const calcTenure = (startDate, endDate) => {
  if (!startDate) return "";
  const start = new Date(startDate);
  const now = new Date();
  const endLabel = endDate && endDate !== "Present" ? endDate : "Present";

  const months =
    now.getFullYear() * 12 + now.getMonth() -
    (start.getFullYear() * 12 + start.getMonth());
  const years = Math.floor(months / 12);
  const remMonths = months % 12;

  const tenure =
    years > 0
      ? `${years} yr${years > 1 ? "s" : ""} ${remMonths} mo`
      : `${remMonths} mo`;

  return `${tenure}`;
};

const detailLines = (details) =>
  details ? details.trim().split("\n").filter((l) => l.trim()) : [];
---

<section class="resume-page container">
  <header class="resume-header">
    <span class="prompt">~/</span>
    <span>resume</span>
  </header>

  <h1 class="resume-title">Experience</h1>

  {Object.entries(resume)
    .filter(([sectionKey]) => sectionKey !== "education")
    .map(([sectionKey, section]) => (
    <section class="resume-section" id={sectionKey}>
      <h2 class="section-heading">
        <span class="heading-icon">{sectionKey === "work" ? "→" : sectionKey === "projects" ? "◈" : "✦"}</span>
        {section.label}
      </h2>
      
      {section.items.length === 0 ? (
        <div class="empty-state">Nothing here yet.</div>
      ) : (
        <div class="item-list">
          {section.items.map((item) => {
            const tenure = calcTenure(item.startDate, item.endDate);
            const lines = detailLines(item.details);
            const showSkills = Array.isArray(item.skills) && item.skills.length;

            return (
              <details class="item-card">
                <summary class="item-summary">
                  <div class="item-top">
                    <div class="item-main">
                      <h3 class="item-title">{item.title}</h3>
                      <p class="item-org">{item.intro}</p>
                    </div>
                    <div class="item-badge">
                      <span class="badge-time">{tenure}</span>
                    </div>
                  </div>
                </summary>

                <div class="item-body">
                  {lines.length > 0 && (
                    <div class="item-block">
                      <ul class="story-list">
                        {lines.map((line, i) => (
                          <li class="story-item">
                            <span class="story-num">{String(i + 1).padStart(2, '0')}</span>
                            <span>{line}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}

                  {showSkills && (
                    <div class="item-block">
                      <div class="skill-list">
                        {item.skills.map((s) => (
                          <span class="skill-tag">{s}</span>
                        ))}
                      </div>
                    </div>
                  )}

                  {item.note && (
                    <div class="item-note">
                      <span class="note-icon">!</span>
                      <p>{item.note}</p>
                    </div>
                  )}
                </div>
              </details>
            );
          })}
        </div>
      )}
    </section>
  ))}
</section>

<style>
  .resume-page {
    padding: 3rem 0;
  }

  @media (min-width: 768px) {
    .resume-page {
      padding: 4rem 0 3rem;
    }
  }

  .resume-header {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .prompt {
    color: var(--accent);
  }

  .resume-title {
    font-size: clamp(1.75rem, 6vw, 3rem);
    font-weight: 700;
    margin-top: 0.5rem;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 768px) {
    .resume-title {
      margin-bottom: 3rem;
    }
  }

  .resume-section {
    margin-bottom: 3rem;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  @media (min-width: 640px) {
    .section-heading {
      font-size: 0.9375rem;
      margin-bottom: 1.5rem;
    }
  }

  .heading-icon {
    color: var(--accent);
    font-size: 1rem;
  }

  .item-list {
    display: grid;
    gap: 1rem;
  }

  .item-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 200ms ease;
  }

  .item-card:hover {
    border-color: var(--border-accent);
  }

  .item-card[open] {
    border-color: var(--accent);
  }

  .item-summary {
    list-style: none;
    cursor: pointer;
    padding: 1.125rem 1.25rem;
  }

  .item-summary::-webkit-details-marker {
    display: none;
  }

  .item-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .item-main {
    flex: 1;
    min-width: 0;
  }

  .item-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: var(--text);
  }

  .item-org {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .item-badge {
    flex-shrink: 0;
  }

  .badge-time {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    background: rgba(255, 107, 53, 0.1);
    border: 1px solid rgba(255, 107, 53, 0.2);
    border-radius: 100px;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6875rem;
    color: var(--accent);
  }

  .item-body {
    padding: 0 1.25rem 1.25rem;
    border-top: 1px solid var(--border);
    display: grid;
    gap: 1.25rem;
  }

  .story-list {
    list-style: none;
    display: grid;
    gap: 0.875rem;
  }

  .story-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    align-items: start;
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .story-num {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.625rem;
    color: var(--accent);
    padding-top: 0.15rem;
  }

  .skill-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    padding: 0.3rem 0.65rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
  }

  .item-note {
    display: flex;
    gap: 0.75rem;
    padding: 0.875rem;
    background: rgba(255, 107, 53, 0.05);
    border: 1px solid rgba(255, 107, 53, 0.15);
    border-radius: 8px;
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .note-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: #000;
    border-radius: 50%;
    font-size: 0.6875rem;
    font-weight: 700;
  }

  .empty-state {
    color: var(--text-dim);
    padding: 2rem;
    text-align: center;
    border: 1px dashed var(--border);
    border-radius: 12px;
    font-size: 0.875rem;
  }

  @media (max-width: 560px) {
    .item-top {
      flex-direction: column;
      gap: 0.75rem;
    }

    .item-badge {
      align-self: flex-start;
    }

    .story-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .story-num {
      display: none;
    }
  }
</style>
