<style>
  .contact-page {
    padding: 3rem 0;
    display: grid;
    gap: 2.5rem;
  }

  @media (min-width: 900px) {
    .contact-page {
      grid-template-columns: 1fr 280px;
      padding: 4rem 0 3rem;
      gap: 3rem;
      align-items: start;
    }
  }

  .contact-left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-header {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .prompt {
    color: var(--accent);
  }

  .contact-title {
    font-size: clamp(2rem, 8vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .contact-bio {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 480px;
  }

  .email-cta {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: all 200ms ease;
    width: fit-content;
  }

  .email-cta:hover {
    border-color: var(--accent);
    background: rgba(255, 107, 53, 0.05);
    transform: translateY(-2px);
  }

  .email-cta-text {
    font-family: "JetBrains Mono", monospace;
    font-size: clamp(0.875rem, 3vw, 1.125rem);
    font-weight: 600;
    color: var(--text);
  }

  .email-cta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--accent);
    border-radius: 10px;
    transition: transform 200ms ease;
  }

  .email-cta:hover .email-cta-icon {
    transform: translateX(4px);
  }

  .email-cta-icon svg {
    width: 20px;
    height: 20px;
    stroke: #000;
  }

  .social-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .social-label {
    font-size: 0.8125rem;
    color: var(--text-dim);
  }

  .social-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 500px) {
    .social-links {
      grid-template-columns: 1fr;
    }
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1.125rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 14px;
    text-decoration: none;
    transition: all 200ms ease;
  }

  .social-link:hover {
    border-color: var(--accent);
    background: rgba(255, 107, 53, 0.03);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(255, 107, 53, 0.08);
  }

  .social-link svg {
    width: 22px;
    height: 22px;
    color: var(--text-muted);
    transition: color 200ms ease;
    flex-shrink: 0;
  }

  .social-link:hover svg {
    color: var(--accent);
  }

  .social-link-content {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .social-link > span:not(.social-handle) {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
  }

  .social-handle {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6875rem;
    color: var(--text-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .social-link-arrow {
    margin-left: auto;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 200ms ease;
  }

  .social-link:hover .social-link-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .social-link-arrow svg {
    width: 16px;
    height: 16px;
    color: var(--accent);
  }

  .contact-aside {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .contact-aside {
      position: sticky;
      top: 2rem;
    }
  }

  .aside-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .aside-card.accent {
    border-color: var(--accent);
    background: rgba(255, 107, 53, 0.05);
  }

  .card-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    border-radius: 8px;
    margin-bottom: 0.25rem;
  }

  .card-icon svg {
    width: 18px;
    height: 18px;
    color: var(--accent);
  }

  .aside-card h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
  }

  .aside-card p {
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.5;
    text-wrap: pretty;
  }

  @media (max-width: 899px) {
    .contact-aside {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }
  }

  @media (max-width: 640px) {
    .social-links {
      gap: 0.6rem;
    }

    .social-link {
      padding: 0.875rem 1rem;
      gap: 0.75rem;
    }

    .social-link svg {
      width: 18px;
      height: 18px;
    }
  }
</style>
