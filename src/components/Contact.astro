---

<section class="contact-page container">
  <div class="contact-left">
    <div class="contact-header">
      <span class="prompt">~/</span>
      <span>contact</span>
    </div>
    
    <h1 class="contact-title">Let's build something.</h1>
    
    <p class="contact-bio">
      Backend engineer focused on payments, security, and systems that actually work. If you've got a hard problem, let's talk.
    </p>

    <a href="mailto:abinash@theabx.in" class="email-cta">
      <span class="email-cta-text">abinash@theabx.in</span>
      <span class="email-cta-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16v12H4z"/><polyline points="4 7 12 13 20 7"/>
        </svg>
      </span>
    </a>

    <div class="social-section">
      <span class="social-label">or find me on</span>
      <div class="social-links">
        <a href="https://github.com/AbiXnash" target="_blank" rel="noreferrer" class="social-link">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.58 2 12.28c0 4.52 2.87 8.36 6.84 9.72.5.1.68-.22.68-.48v-1.7c-2.78.62-3.37-1.4-3.37-1.4-.45-1.16-1.1-1.47-1.1-1.47-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.9 1.56 2.36 1.11 2.94.85.09-.67.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.32.1-2.75 0 0 .84-.28 2.75 1.05a9.4 9.4 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.43.2 2.49.1 2.75.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.78-4.57 5.03.36.32.68.94.68 1.9v2.82c0 .26.18.58.69.48A10.3 10.3 0 0 0 22 12.28C22 6.58 17.52 2 12 2z"/>
          </svg>
          <span>GitHub</span>
          <span class="social-handle">@AbiXnash</span>
        </a>
        <a href="https://linkedin.com/in/abinash-selvarasu" target="_blank" rel="noreferrer" class="social-link">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM3 9h4v12H3zM9 9h3.8v1.6h.05c.53-1 1.83-2.1 3.75-2.1C20 8.5 21 10.7 21 14v7h-4v-6.2c0-1.5 0-3.4-2.1-3.4s-2.4 1.6-2.4 3.3V21H9z"/>
          </svg>
          <span>LinkedIn</span>
          <span class="social-handle">abinash-selvarasu</span>
        </a>
        <a href="https://x.com/theabxguy" target="_blank" rel="noreferrer" class="social-link">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2H21.6l-7.53 8.61L22.5 22h-6.6l-5.17-6.63L4.9 22H1.5l8.06-9.21L1.5 2h6.75l4.67 6.05L18.24 2z"/>
          </svg>
          <span>X</span>
          <span class="social-handle">@theabxguy</span>
        </a>
      </div>
    </div>
  </div>

  <div class="contact-aside">
    <div class="aside-card">
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <h3>Response time</h3>
      <p>24-48 hours. Fast replies for interesting problems.</p>
    </div>

    <div class="aside-card">
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
      </div>
      <h3>Open to</h3>
      <p>Contract & consulting in payments/security/backend.</p>
    </div>

    <div class="aside-card accent">
      <div class="card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <h3>Remote first</h3>
      <p>Async-friendly. Time zones aren't a problem if the work matters.</p>
    </div>
  </div>
</section>

<style>
  .contact-page {
    padding: 3rem 0;
    display: grid;
    gap: 2.5rem;
  }

  @media (min-width: 900px) {
    .contact-page {
      grid-template-columns: 1fr 280px;
      padding: 4rem 0 3rem;
      gap: 3rem;
      align-items: start;
    }
  }

  .contact-left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-header {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .prompt {
    color: var(--accent);
  }

  .contact-title {
    font-size: clamp(2rem, 8vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .contact-bio {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 480px;
  }

  .email-cta {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: all 200ms ease;
    width: fit-content;
  }

  .email-cta:hover {
    border-color: var(--accent);
    background: rgba(255, 107, 53, 0.05);
    transform: translateY(-2px);
  }

  .email-cta-text {
    font-family: "JetBrains Mono", monospace;
    font-size: clamp(0.875rem, 3vw, 1.125rem);
    font-weight: 600;
    color: var(--text);
  }

  .email-cta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--accent);
    border-radius: 10px;
    transition: transform 200ms ease;
  }

  .email-cta:hover .email-cta-icon {
    transform: translateX(4px);
  }

  .email-cta-icon svg {
    width: 20px;
    height: 20px;
    stroke: #000;
  }

  .social-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .social-label {
    font-size: 0.8125rem;
    color: var(--text-dim);
  }

  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .social-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: all 200ms ease;
  }

  .social-link:hover {
    border-color: var(--accent);
    transform: translateX(4px);
  }

  .social-link svg {
    width: 22px;
    height: 22px;
    color: var(--text-muted);
    transition: color 200ms ease;
  }

  .social-link:hover svg {
    color: var(--accent);
  }

  .social-link > span:not(.social-handle) {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text);
  }

  .social-handle {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .contact-aside {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 900px) {
    .contact-aside {
      position: sticky;
      top: 2rem;
    }
  }

  .aside-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .aside-card.accent {
    border-color: var(--accent);
    background: rgba(255, 107, 53, 0.05);
  }

  .card-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    border-radius: 8px;
    margin-bottom: 0.25rem;
  }

  .card-icon svg {
    width: 18px;
    height: 18px;
    color: var(--accent);
  }

  .aside-card h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
  }

  .aside-card p {
    font-size: 0.8125rem;
    color: var(--text-muted);
    line-height: 1.5;
    text-wrap: pretty;
  }

  @media (max-width: 899px) {
    .contact-aside {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }
  }

  @media (max-width: 640px) {
    .social-links {
      gap: 0.6rem;
    }

    .social-link {
      padding: 0.875rem 1rem;
      gap: 0.75rem;
    }

    .social-link svg {
      width: 18px;
      height: 18px;
    }
  }
</style>
