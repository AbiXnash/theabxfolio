---
const username = "AbiXnash";
---

<section class="hero container">
  <div class="hero-left">
    <div class="hero-label">
      <span class="prompt">~/</span>
      <span>portfolio</span>
    </div>
    
    <h1 class="hero-name">Abinash Selvarasu</h1>
    
    <p class="hero-role">
      <span class="role-dot"></span>
      Backend Engineer
    </p>

    <p class="hero-bio">
      Building resilient payment systems and security-focused platforms.
    </p>

    <div class="hero-tags">
      <span class="tag">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
        </svg>
        Payments
      </span>
      <span class="tag">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Security
      </span>
      <span class="tag">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
        </svg>
        APIs
      </span>
      <span class="tag">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        Microservices
      </span>
    </div>

    <div class="hero-actions">
      <a href="/resume" class="btn btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg>
        Resume
      </a>
      <a href="/contact" class="btn btn-ghost">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16v12H4z"/><polyline points="4 7 12 13 20 7"/>
        </svg>
        Contact
      </a>
    </div>
  </div>

  <div class="hero-right">
    <div class="activity-card" data-activity-shell data-activity-url="/github-activity.json" data-github-profile={`https://github.com/${username}`}>
      <div class="activity-header">
        <div class="header-left">
          <div class="header-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <span class="mono">gh activity</span>
        </div>
        <span class="header-status">
          <span class="status-indicator"></span>
          live
        </span>
      </div>
      
      <div class="commits-header">
        <span class="commits-label">Recent commits</span>
        <span class="commits-count" id="commitsCount"></span>
      </div>
      
      <div class="activity-body">
        <div class="activity-loader" aria-hidden="true">
          <div class="loader-bars">
            <span></span><span></span><span></span>
          </div>
          <span class="loading-text">loading...</span>
        </div>
        <div id="repoList" class="repo-list"></div>
      </div>
    </div>

    <div class="stats-row">
      <div class="stat-item">
        <span class="stat-value">5+</span>
        <span class="stat-label">Years</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">50+</span>
        <span class="stat-label">Projects</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-value">99.9%</span>
        <span class="stat-label">Uptime</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem 0;
  }

  @media (min-width: 768px) {
    .hero {
      display: grid;
      grid-template-columns: 1fr 340px;
      padding: 3rem 0;
      gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      grid-template-columns: 1fr 400px;
      padding: 4rem 0;
    }
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .prompt {
    color: var(--accent);
  }

  .hero-name {
    font-size: clamp(1.75rem, 8vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--text) 0%, var(--text-muted) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .hero-role {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .role-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero-bio {
    font-size: 1.0625rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.65rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.6875rem;
    color: var(--text-muted);
  }

  .tag svg {
    width: 12px;
    height: 12px;
    stroke: var(--accent);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    font-size: 0.8125rem;
    font-weight: 600;
    transition: all 200ms ease;
  }

  .btn svg {
    width: 16px;
    height: 16px;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
    border: none;
  }

  .btn-ghost {
    background: var(--bg-elevated);
    color: var(--text);
    border: 1px solid var(--border);
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }

  .activity-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .activity-header {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.875rem;
    border-bottom: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.2);
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .header-dots {
    display: flex;
    gap: 0.3rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green { background: #28c840; }

  .mono {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.6875rem;
    color: var(--text-dim);
  }

  .header-status {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.5625rem;
    color: #28c840;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-indicator {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #28c840;
    animation: blink 1.5s ease-in-out infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .activity-body {
    padding: 0.5rem;
    min-height: 120px;
    max-height: 200px;
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .activity-body::-webkit-scrollbar {
    display: none;
  }

  @media (min-width: 640px) {
    .activity-body {
      padding: 0.75rem;
      min-height: 150px;
      max-height: 250px;
    }
  }

  .commits-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.875rem;
    border-bottom: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.1);
  }

  .commits-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.625rem;
    color: var(--text-muted);
  }

  .commits-count {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.5625rem;
    color: var(--accent);
    background: rgba(255, 107, 53, 0.1);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
  }

  .activity-loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.5rem;
  }

  .loader-bars {
    display: flex;
    gap: 3px;
  }

  .loader-bars span {
    width: 3px;
    height: 16px;
    background: var(--accent);
    border-radius: 2px;
    animation: loaderBounce 1s ease-in-out infinite;
  }

  .loader-bars span:nth-child(1) { animation-delay: 0s; }
  .loader-bars span:nth-child(2) { animation-delay: 0.1s; }
  .loader-bars span:nth-child(3) { animation-delay: 0.2s; }

  @keyframes loaderBounce {
    0%, 100% { transform: scaleY(0.5); opacity: 0.5; }
    50% { transform: scaleY(1); opacity: 1; }
  }

  .loading-text {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.625rem;
    color: var(--text-dim);
  }

  .activity-card.is-ready .activity-loader {
    display: none !important;
  }

  .stats-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 10px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }

  .stat-value {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent);
    font-family: "JetBrains Mono", monospace;
  }

  .stat-label {
    font-size: 0.5rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-divider {
    width: 1px;
    height: 24px;
    background: var(--border);
  }

  .repo-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .commit-item {
    display: flex;
    gap: 0.5rem;
    padding: 0.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 150ms ease;
  }

  .commit-item:hover {
    background: rgba(255, 255, 255, 0.03);
  }

  .commit-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
  }

  .commit-icon svg {
    width: 14px;
    height: 14px;
    stroke: var(--accent);
  }

  .commit-content {
    flex: 1;
    min-width: 0;
  }

  .commit-message {
    color: var(--text);
    word-break: break-word;
    line-height: 1.35;
    font-size: 0.6875rem;
    font-family: "JetBrains Mono", monospace;
  }

  .commit-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem 0.5rem;
    font-size: 0.5625rem;
    margin-top: 0.25rem;
  }

  .commit-sha {
    color: var(--accent);
    font-family: "JetBrains Mono", monospace;
    font-weight: 500;
  }

  .commit-repo {
    color: var(--text-muted);
    font-family: "JetBrains Mono", monospace;
  }

  .commit-repo::before {
    content: "in ";
    color: var(--text-dim);
  }

  .commit-time {
    color: var(--text-dim);
    margin-left: auto;
    white-space: nowrap;
  }

  .repo-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.5rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 0.6875rem;
  }

  .repo-empty svg {
    width: 24px;
    height: 24px;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const shell = document.querySelector("[data-activity-shell]");
    if (!shell) return;
    const repoList = shell.querySelector("#repoList");
    const commitsCount = shell.querySelector("#commitsCount");
    const activityUrl = shell.getAttribute("data-activity-url");
    if (!repoList || !activityUrl) return;

    const escapeHtml = (value) =>
      String(value).replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      }[char] || char));

    const formatTime = (iso) => {
      const date = new Date(iso);
      const now = new Date();
      const diff = now - date;
      const hours = Math.floor(diff / 3600000);
      const days = Math.floor(diff / 86400000);
      if (hours < 1) return 'just now';
      if (hours < 24) return `${hours}h ago`;
      if (days < 7) return `${days}d ago`;
      return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    };

    const renderActivity = (payload) => {
      if (!payload?.items?.length) {
        repoList.innerHTML = `
          <div class="repo-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
            <span>no commits found</span>
          </div>
        `;
        if (commitsCount) commitsCount.textContent = '0';
        return;
      }

      const count = payload.items.length;
      if (commitsCount) commitsCount.textContent = count.toString();

      const commitsHtml = payload.items
        .slice(0, 5)
        .map(
          (commit) => `
          <a href="${escapeHtml(commit.htmlUrl)}" target="_blank" rel="noreferrer" class="commit-item">
            <div class="commit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="4"/>
                <line x1="1.05" y1="12" x2="7" y2="12"/>
                <line x1="17.01" y1="12" x2="22.96" y2="12"/>
              </svg>
            </div>
            <div class="commit-content">
              <div class="commit-message">${escapeHtml(commit.message)}</div>
              <div class="commit-meta">
                <span class="commit-sha">${escapeHtml(commit.sha?.slice(0, 7) || "")}</span>
                <span class="commit-repo">${escapeHtml(commit.repoName)}</span>
                <span class="commit-time">${formatTime(commit.date)}</span>
              </div>
            </div>
          </a>
        `,
        )
        .join("");

      repoList.innerHTML = commitsHtml;
    };

    shell.classList.add("is-ready");

    fetch(activityUrl)
      .then((res) => res.json())
      .then(renderActivity)
      .catch(() => {
        repoList.innerHTML = `
          <div class="repo-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>failed to load</span>
          </div>
        `;
      });
  });
</script>
