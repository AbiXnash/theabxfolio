---
import { getRecentGithubActivity } from "../lib/githubActivity";

const username = "AbiXnash";
const githubActivity = await getRecentGithubActivity(username, 5);
const recentCommits = githubActivity.items;
const isDev = import.meta.env.DEV;
const showTokenHint = isDev && githubActivity.error === "rate-limited";

const formatDate = (iso: string) =>
  new Intl.DateTimeFormat("en-US", {
    dateStyle: "medium",
    timeStyle: "short",
  }).format(new Date(iso));

const shortSha = (sha: string) => (sha ? sha.slice(0, 7) : "");
---

<section class="page-shell hero-shell">
  <div class="page-inner hero-layout">
    <div class="hero-content" data-reveal>
      <span class="hero-kicker">Backend Engineer</span>
      <h1 class="hero-title">Abinash S</h1>
      <p class="hero-subtitle">
        Building resilient payment systems and security-focused platforms with clean architecture and
        measured performance.
      </p>

      <div class="hero-actions">
        <a href="/resume" class="btn-primary">View Resume</a>
        <a href="/service" class="btn-ghost">Services</a>
        <a href="/contact" class="btn-ghost">Contact</a>
      </div>

      <div class="hero-tags">
        <span class="tag">Payments · Microservices</span>
        <span class="tag">Security · Reliability</span>
        <span class="tag">Java · Spring Boot</span>
      </div>
    </div>

    <div class="card contact-activity" data-reveal>
      <h2 class="section-title">GitHub Activity</h2>
      <p class="activity-badge">Available for select projects</p>
      <p class="section-subtitle">
        Latest commits from recent public GitHub push activity.
      </p>
      <div id="repoList" class="repo-list">
        {
          recentCommits.length ? (
            <div class="repo-item">
              <div class="repo-head">
                <div>
                  <div class="repo-badge">Recent commits</div>
                  <div class="repo-title">Latest activity</div>
                  <div class="repo-desc">Build-time snapshot from public GitHub events</div>
                </div>
                <a class="repo-link" href={`https://github.com/${username}`} target="_blank">View GitHub</a>
              </div>
              <div class="commit-list">
                {recentCommits.map((commit) => (
                  <div class="commit-item">
                    <div class="commit-message">{commit.message}</div>
                    <div class="commit-meta">
                      <span class="commit-sha">{shortSha(commit.sha)}</span>
                      <a class="commit-repo" href={commit.htmlUrl} target="_blank">
                        {commit.repoName}
                      </a>
                      <span>{formatDate(commit.date)}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ) : (
            <div class="repo-empty">
              GitHub activity is temporarily unavailable.
              {isDev ? " Check the Astro dev terminal for the GitHub fetch error." : ""}
            </div>
          )
        }
        {
          showTokenHint && (
            <div class="repo-empty repo-hint">
              GitHub API rate limit hit. Set <code>GITHUB_TOKEN</code> or <code>GH_TOKEN</code> before
              running <code>bun dev</code>.
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .hero-shell {
    min-height: calc(100vh - 220px);
    display: flex;
    align-items: center;
  }

  .hero-layout {
    display: grid;
    gap: 3rem;
  }

  .hero-content {
    display: grid;
    gap: 1.3rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .contact-activity {
    display: grid;
    gap: 1rem;
    max-height: 520px;
    overflow: auto;
  }

  .activity-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  :global(.repo-list) {
    display: grid;
    gap: 0.8rem;
  }

  :global(.repo-item) {
    display: grid;
    gap: 0.9rem;
    padding: 0.9rem 1rem;
    border-radius: 14px;
    border: 1px solid rgba(205, 214, 244, 0.12);
    background: rgba(17, 17, 27, 0.6);
    color: var(--text-primary);
    box-shadow: inset 0 0 0 1px rgba(205, 214, 244, 0.04);
  }

  :global(.repo-head) {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 0.8rem;
  }

  :global(.repo-badge) {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  :global(.repo-title) {
    font-size: 0.95rem;
    font-weight: 600;
  }

  :global(.repo-desc) {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
  }

  :global(.repo-link) {
    font-size: 0.75rem;
    color: var(--accent-alt);
    white-space: nowrap;
  }

  :global(.commit-list) {
    display: grid;
    gap: 0.6rem;
    border-left: 1px solid rgba(205, 214, 244, 0.12);
    padding-left: 0.8rem;
  }

  :global(.commit-item) {
    padding: 0.6rem 0.7rem;
    border-radius: 12px;
    border: 1px solid rgba(205, 214, 244, 0.08);
    background: rgba(17, 17, 27, 0.5);
    display: grid;
    gap: 0.35rem;
    position: relative;
  }

  :global(.commit-item::before) {
    content: "";
    position: absolute;
    left: -1.15rem;
    top: 0.9rem;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--accent-alt);
    box-shadow: 0 0 0 4px rgba(137, 180, 250, 0.15);
  }

  :global(.commit-message) {
    font-size: 0.82rem;
    color: var(--text-primary);
  }

  :global(.commit-meta) {
    font-size: 0.7rem;
    color: var(--text-dim);
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  :global(.commit-sha) {
    font-family: "JetBrains Mono", monospace;
    color: var(--accent-alt);
  }

  :global(.commit-repo) {
    color: var(--accent-alt);
  }

  :global(.commit-repo:hover) {
    color: var(--text-primary);
  }

  :global(.repo-empty) {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  :global(.skeleton) {
    height: 64px;
    border-radius: 14px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.06));
    background-size: 200% 100%;
    animation: shimmer 1.2s infinite;
  }

  @media (min-width: 980px) {
    .hero-layout {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      align-items: center;
    }
  }

  @media (max-width: 720px) {
    .panel-foot {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>
