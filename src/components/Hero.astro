<script>
  const GITHUB_API_BASE = "https://api.github.com";
  const USERNAME = "AbiXnash";
  const COMMIT_LIMIT = 5;
  const CACHE_TTL_MS = 60 * 1000;

  const getCachedActivity = () => {
    try {
      const cached = sessionStorage.getItem("github-activity-cache");
      if (!cached) return null;
      const { data, timestamp } = JSON.parse(cached);
      if (Date.now() - timestamp > CACHE_TTL_MS) return null;
      return data;
    } catch { return null; }
  };

  const setCachedActivity = (data) => {
    try {
      sessionStorage.setItem("github-activity-cache", JSON.stringify({ data, timestamp: Date.now() }));
    } catch {}
  };

  document.addEventListener("DOMContentLoaded", () => {
    const shell = document.querySelector("[data-activity-shell]");
    if (!shell) return;
    
    const repoList = document.querySelector("#repoList");
    const commitsCount = document.querySelector("#commitsCount");
    if (!repoList) return;

    const escapeHtml = (value) =>
      String(value).replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      }[char] || char));

    const formatTime = (iso) => {
      const date = new Date(iso);
      const now = new Date();
      const diff = now - date;
      const hours = Math.floor(diff / 3600000);
      const days = Math.floor(diff / 86400000);
      if (hours < 1) return 'just now';
      if (hours < 24) return `${hours}h ago`;
      if (days < 7) return `${days}d ago`;
      return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    };

    const renderActivity = (commits) => {
      if (!commits.length) {
        repoList.innerHTML = `
          <div class="repo-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
            <span>no commits found</span>
          </div>
        `;
        if (commitsCount) commitsCount.textContent = '0';
        return;
      }

      if (commitsCount) commitsCount.textContent = commits.length.toString();

      const commitsHtml = commits
        .slice(0, COMMIT_LIMIT)
        .map(
          (commit) => `
          <a href="${escapeHtml(commit.htmlUrl)}" target="_blank" rel="noreferrer" class="commit-item">
            <div class="commit-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="4"/>
                <line x1="1.05" y1="12" x2="7" y2="12"/>
                <line x1="17.01" y1="12" x2="22.96" y2="12"/>
              </svg>
            </div>
            <div class="commit-content">
              <div class="commit-message">${escapeHtml(commit.message)}</div>
              <div class="commit-meta">
                <span class="commit-sha">${escapeHtml(commit.sha?.slice(0, 7) || "")}</span>
                <span class="commit-repo">${escapeHtml(commit.repoName)}</span>
                <span class="commit-time">${formatTime(commit.date)}</span>
              </div>
            </div>
          </a>
        `,
        )
        .join("");

      repoList.innerHTML = commitsHtml;
    };

    const fetchActivity = async () => {
      try {
        const headers: Record<string, string> = {
          Accept: "application/vnd.github+json",
          "X-GitHub-Api-Version": "2022-11-28",
        };
        
        const token = import.meta.env.VITE_THE_REPO_TOKEN || import.meta.env.VITE_GITHUB_TOKEN || import.meta.env.THE_REPO_TOKEN || import.meta.env.GITHUB_TOKEN;
        const hasToken = !!(token && (token.startsWith("ghp_") || token.startsWith("github_pat_")));
        if (hasToken) {
          headers.Authorization = `Bearer ${token}`;
        }

        const response = await fetch(
          `${GITHUB_API_BASE}/users/${USERNAME}/events/public?per_page=100`,
          { headers }
        );
        
        if (!response.ok) {
          throw new Error(`GitHub API ${response.status}`);
        }

        const events = await response.json();
        
        let commits = events
          .filter((e) => e.type === "PushEvent" && e.created_at && e.repo)
          .flatMap((e) =>
            (e.payload?.commits || []).map((c) => ({
              date: e.created_at,
              htmlUrl: `https://github.com/${e.repo.name}`,
              message: c.message || "Commit",
              repoName: e.repo.name.split("/")[1],
              sha: c.sha || "",
            }))
          )
          .filter((c) => c.date)
          .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
          .slice(0, COMMIT_LIMIT);

        if (!commits.length) {
          const repos = events
            .filter((e) => e.type === "PushEvent" && e.repo?.name)
            .map((e) => e.repo.name.split("/")[1])
            .filter((v, i, a) => a.indexOf(v) === i)
            .slice(0, 5);

          const recentCommits = await Promise.all(
            repos.map(async (repo) => {
              try {
                const res = await fetch(`${GITHUB_API_BASE}/repos/${USERNAME}/${repo}/commits?per_page=1`, { headers });
                if (!res.ok || res.status === 404) {
                  return null;
                }
                const data = await res.json();
                if (!data[0]) return null;
                return {
                  date: data[0].commit?.author?.date,
                  htmlUrl: `https://github.com/${USERNAME}/${repo}`,
                  message: data[0].commit?.message || "Commit",
                  repoName: repo,
                  sha: data[0].sha || "",
                };
              } catch { 
                return null; 
              }
            })
          );
          commits = recentCommits.filter(Boolean).slice(0, COMMIT_LIMIT);
        }

        renderActivity(commits);
        setCachedActivity(commits);
      } catch (err) {
        repoList.innerHTML = `
          <div class="repo-empty">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>failed to load</span>
          </div>
        `;
      }
    };

    shell.classList.add("is-ready");

    const cached = getCachedActivity();
    if (cached) {
      renderActivity(cached);
      fetchActivity();
    } else {
      fetchActivity();
    }
  });
</script>
