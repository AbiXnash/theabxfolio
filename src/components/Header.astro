---
const isActive = (href: string) => Astro.url.pathname === href;
---

<header class="header" role="banner">
  <div class="header-inner container">
    <a href="/" class="logo" itemprop="url">
      <span class="brand-mark" aria-hidden="true">$</span>
      <span class="brand-copy">
        <span class="brand-name" itemprop="name">abx</span>
        <span class="brand-role">Software Engineer</span>
      </span>
    </a>

    <nav class="nav-desktop" role="navigation" aria-label="Main navigation">
      <span class="nav-caption mono">explore</span>
      <div class="nav-track">
        <a href="/" class:list={["nav-link", { active: isActive("/") }]} itemprop="url">home</a>
        <a href="/resume" class:list={["nav-link", { active: isActive("/resume") }]} itemprop="url">resume</a>
        <a href="/contact" class:list={["nav-link", { active: isActive("/contact") }]} itemprop="url">contact</a>
      </div>
    </nav>

    <div class="header-actions">
      <span class="header-side-note mono">connect</span>
      <div class="nav-social" role="navigation" aria-label="Social links">
        <a href="https://github.com/AbiXnash" target="_blank" rel="me noreferrer noopener" class="social-link" aria-label="GitHub profile" itemprop="sameAs">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.58 2 12.28c0 4.52 2.87 8.36 6.84 9.72.5.1.68-.22.68-.48v-1.7c-2.78.62-3.37-1.4-3.37-1.4-.45-1.16-1.1-1.47-1.1-1.47-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.9 1.56 2.36 1.11 2.94.85.09-.67.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.32.1-2.75 0 0 .84-.28 2.75 1.05a9.4 9.4 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.43.2 2.49.1 2.75.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.78-4.57 5.03.36.32.68.94.68 1.9v2.82c0 .26.18.58.69.48A10.3 10.3 0 0 0 22 12.28C22 6.58 17.52 2 12 2z"/>
          </svg>
        </a>
        <a href="https://linkedin.com/in/abinash-selvarasu" target="_blank" rel="me noreferrer noopener" class="social-link" aria-label="LinkedIn profile" itemprop="sameAs">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>

      <button class="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobileNav" id="mobileMenuBtn">
        <span class="mobile-menu-text">menu</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<div class="mobile-nav-overlay" id="mobileOverlay" aria-hidden="true"></div>

<nav class="mobile-nav" id="mobileNav" role="navigation" aria-label="Mobile navigation" aria-hidden="true">
  <div class="mobile-nav-header">
    <div class="mobile-nav-intro">
      <span class="mobile-nav-kicker">Menu</span>
      <span class="mobile-nav-brand">
        <span class="brand-mark" aria-hidden="true">$</span>
        <span class="brand-name">abx</span>
      </span>
      <p class="mobile-nav-label">Software Engineer building reliable backend systems and practical products.</p>
    </div>
    <button class="mobile-nav-close" id="mobileNavClose" aria-label="Close menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  
  <div class="mobile-nav-links">
    <a href="/" class:list={["mobile-nav-link", { active: isActive("/") }]}>
      <span class="mobile-link-copy">
        <span class="link-icon">~/</span>
        <span class="mobile-link-label">home</span>
      </span>
    </a>
    <a href="/resume" class:list={["mobile-nav-link", { active: isActive("/resume") }]}>
      <span class="mobile-link-copy">
        <span class="link-icon">~/</span>
        <span class="mobile-link-label">resume</span>
      </span>
    </a>
    <a href="/contact" class:list={["mobile-nav-link", { active: isActive("/contact") }]}>
      <span class="mobile-link-copy">
        <span class="link-icon">~/</span>
        <span class="mobile-link-label">contact</span>
      </span>
    </a>
  </div>

  <div class="mobile-nav-footer">
    <a href="https://github.com/AbiXnash" target="_blank" rel="noreferrer" class="mobile-nav-social">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.48 2 2 6.58 2 12.28c0 4.52 2.87 8.36 6.84 9.72.5.1.68-.22.68-.48v-1.7c-2.78.62-3.37-1.4-3.37-1.4-.45-1.16-1.1-1.47-1.1-1.47-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.9 1.56 2.36 1.11 2.94.85.09-.67.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.32.1-2.75 0 0 .84-.28 2.75 1.05a9.4 9.4 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.43.2 2.49.1 2.75.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.78-4.57 5.03.36.32.68.94.68 1.9v2.82c0 .26.18.58.69.48A10.3 10.3 0 0 0 22 12.28C22 6.58 17.52 2 12 2z"/>
      </svg>
      <span>@AbiXnash</span>
    </a>
    <a href="https://linkedin.com/in/abinash-selvarasu" target="_blank" rel="noreferrer" class="mobile-nav-social">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      <span class="social-name">@abinash-selvarasu</span>
    </a>
  </div>
</nav>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding-top: 0.3rem;
    background: linear-gradient(180deg, rgba(8, 8, 8, 0.82), rgba(8, 8, 8, 0.38));
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    transition:
      background 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .header-inner {
    display: flex;
    position: relative;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.58rem 0.85rem;
    width: 100%;
    margin: 0 auto;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    background:
      radial-gradient(circle at top right, rgba(255, 107, 53, 0.12), transparent 30%),
      linear-gradient(135deg, rgba(255, 107, 53, 0.06), rgba(255, 255, 255, 0.015)),
      rgba(255, 255, 255, 0.01);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 16px 34px rgba(0, 0, 0, 0.14);
  }

  @media (min-width: 640px) {
    .header-inner {
      padding: 0.62rem 0.95rem;
    }
  }

  @media (min-width: 768px) {
    .header-inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      align-items: center;
      gap: 0.85rem;
      padding-top: 0.62rem;
      padding-bottom: 0.62rem;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
    padding: 0.05rem;
    transition: opacity 160ms ease, transform 160ms ease;
  }

  .logo:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .nav-desktop {
    display: none;
    align-items: center;
    gap: 0.45rem;
    padding: 0.18rem 0.22rem 0.18rem 0.68rem;
    border-radius: 16px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015)),
      rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.03) inset,
      0 10px 18px rgba(0, 0, 0, 0.08);
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
      justify-self: center;
    }
  }

  .nav-caption {
    font-size: 0.56rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .nav-track {
    display: flex;
    align-items: center;
    gap: 0.16rem;
    padding: 0.18rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.8rem;
    padding: 0.32rem 0.68rem;
    border-radius: 10px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--text-muted);
    transition:
      color 160ms ease,
      background 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease,
      border-color 160ms ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-link.active {
    color: var(--text);
    background:
      linear-gradient(180deg, rgba(255, 107, 53, 0.14), rgba(255, 107, 53, 0.05)),
      rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 107, 53, 0.24);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.03) inset,
      0 8px 18px rgba(255, 107, 53, 0.12);
    animation: navActivePulse 420ms ease-out;
  }

  .nav-social {
    display: none;
    gap: 0.5rem;
  }

  @media (min-width: 768px) {
    .nav-social {
      display: flex;
    }
  }

  @media (max-width: 900px) {
    .nav-caption {
      display: none;
    }

    .nav-desktop {
      padding-left: 0.24rem;
    }
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-left: auto;
  }

  @media (min-width: 768px) {
    .header-actions {
      justify-self: end;
      margin-left: 0;
    }
  }

  .brand-mark {
    font-family: "JetBrains Mono", monospace;
    color: var(--accent);
    font-weight: 500;
    font-size: 0.8rem;
    text-shadow: 0 0 10px rgba(255, 107, 53, 0.5);
  }

  .brand-name {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text);
  }

  .brand-copy {
    display: grid;
    gap: 0.02rem;
    min-width: 0;
  }

  .brand-role {
    font-size: 0.58rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .header-side-note {
    display: none;
    padding: 0.18rem 0.42rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.07);
    font-size: 0.54rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (min-width: 960px) {
    .header-side-note {
      display: inline-flex;
      align-items: center;
    }
  }

  .social-link,
  .mobile-nav-social {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    background: rgba(15, 15, 15, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition:
      color 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      transform 180ms ease;
  }

  .social-link:hover,
  .mobile-nav-social:hover {
    color: var(--text);
    border-color: rgba(255, 107, 53, 0.35);
    background: rgba(255, 107, 53, 0.08);
  }

  .social-link {
    width: 30px;
    height: 30px;
    border-radius: 8px;
  }

  .social-link:hover {
    transform: translateY(-2px);
  }

  .social-link svg {
    width: 16px;
    height: 16px;
  }

  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-width: 40px;
    height: 40px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01)),
      rgba(16, 16, 16, 0.72);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 12px 24px rgba(0, 0, 0, 0.14);
    border-radius: 999px;
    cursor: pointer;
    transition:
      transform 150ms ease,
      border-color 150ms ease,
      background 150ms ease,
      box-shadow 150ms ease;
    padding: 0 0.75rem;
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .mobile-menu-btn:hover {
    border-color: rgba(255, 107, 53, 0.35);
    background:
      linear-gradient(180deg, rgba(255, 107, 53, 0.12), rgba(255, 107, 53, 0.04)),
      rgba(16, 16, 16, 0.78);
    transform: translateY(-1px);
  }

  .mobile-menu-btn[aria-expanded='true'] {
    border-color: rgba(255, 107, 53, 0.35);
    background:
      linear-gradient(180deg, rgba(255, 107, 53, 0.14), rgba(255, 107, 53, 0.05)),
      rgba(16, 16, 16, 0.82);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 16px 28px rgba(0, 0, 0, 0.2);
  }

  .mobile-menu-text {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .mobile-menu-btn svg {
    width: 16px;
    height: 16px;
    color: var(--text-muted);
  }

  .mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    z-index: 200;
    opacity: 0;
    transition: opacity 200ms ease;
  }

  .mobile-nav-overlay.open {
    display: block;
    opacity: 1;
  }

  .mobile-nav {
    position: fixed;
    top: 0.9rem;
    left: 1rem;
    right: 1rem;
    background:
      radial-gradient(circle at top right, rgba(255, 107, 53, 0.14), transparent 34%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.015)),
      rgba(14, 14, 14, 0.94);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 26px;
    padding: 1.1rem 1rem 1rem;
    z-index: 201;
    transform: translateY(-1rem);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 240ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 240ms ease;
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 28px 54px rgba(0, 0, 0, 0.38);
  }

  .mobile-nav.open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 0 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: 0.9rem;
  }

  .mobile-nav-intro {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
  }

  .mobile-nav-kicker {
    display: inline-flex;
    width: fit-content;
    padding: 0.24rem 0.55rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.64rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .mobile-nav-brand {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 1rem;
  }

  .mobile-nav-label {
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.6;
    max-width: 30ch;
  }

  .mobile-nav-close {
    width: 42px;
    height: 42px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    cursor: pointer;
    transition:
      transform 150ms ease,
      border-color 150ms ease,
      background 150ms ease;
  }

  .mobile-nav-close:hover {
    border-color: rgba(255, 107, 53, 0.35);
    background: rgba(255, 107, 53, 0.1);
    transform: rotate(90deg);
  }

  .mobile-nav-close svg {
    width: 20px;
    height: 20px;
    color: var(--text-muted);
    stroke-width: 2;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding-top: 0.15rem;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 1rem 1rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.015)),
      rgba(13, 13, 13, 0.58);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 16px;
    font-size: 0.98rem;
    font-weight: 500;
    color: var(--text-muted);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease,
      box-shadow 180ms ease;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    border-color: rgba(255, 107, 53, 0.4);
    color: var(--text);
    background:
      linear-gradient(180deg, rgba(255, 107, 53, 0.12), rgba(255, 107, 53, 0.04)),
      rgba(13, 13, 13, 0.62);
    box-shadow: 0 12px 22px rgba(0, 0, 0, 0.18);
    transform: translateY(-1px);
  }

  .mobile-nav-link.active {
    color: var(--text);
  }

  .mobile-nav-link::after {
    content: '->';
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.32);
    transition: color 160ms ease, transform 160ms ease;
  }

  .mobile-nav-link:hover::after,
  .mobile-nav-link.active::after {
    color: var(--accent);
    transform: translateX(2px);
  }

  .mobile-nav-link.active .link-icon {
    color: var(--accent);
  }

  .mobile-link-copy {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .mobile-link-label {
    color: inherit;
  }

  .link-icon {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .mobile-nav-footer {
    display: flex;
    gap: 0.65rem;
    margin-top: 1.2rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .mobile-nav-social {
    flex: 1;
    gap: 0.5rem;
    justify-content: flex-start;
    padding: 0.9rem 1rem;
    border-radius: 14px;
    font-size: 0.8rem;
    min-width: 0;
  }

  .mobile-nav-social svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .social-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 420px) {
    .mobile-nav {
      left: 0.75rem;
      right: 0.75rem;
      top: 0.75rem;
      padding: 1rem 0.85rem 0.9rem;
    }

    .mobile-nav-footer {
      flex-direction: column;
    }
  }

  @keyframes navActivePulse {
    0% {
      box-shadow: 0 0 0 rgba(255, 107, 53, 0);
    }
    100% {
      box-shadow: 0 8px 18px rgba(255, 107, 53, 0.18);
    }
  }
</style>

<script>
  const btn = document.getElementById('mobileMenuBtn');
  const nav = document.getElementById('mobileNav');
  const overlay = document.getElementById('mobileOverlay');
  const closeBtn = document.getElementById('mobileNavClose');
  
  function openNav() {
    nav?.classList.add('open');
    overlay?.classList.add('open');
    nav?.setAttribute('aria-hidden', 'false');
    btn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  
  function closeNav() {
    nav?.classList.remove('open');
    overlay?.classList.remove('open');
    nav?.setAttribute('aria-hidden', 'true');
    btn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }
  
  btn?.addEventListener('click', () => {
    if (nav?.classList.contains('open')) {
      closeNav();
      return;
    }

    openNav();
  });
  closeBtn?.addEventListener('click', closeNav);
  overlay?.addEventListener('click', closeNav);
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && nav?.classList.contains('open')) {
      closeNav();
    }
  });
  
  nav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeNav);
  });
</script>
