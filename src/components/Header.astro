---
const isActive = (href) => Astro.url.pathname === href;
---

<header class="header">
  <div class="header-inner container">
    <a href="/" class="logo">
      <span class="logo-mark">$</span>
      <span class="logo-name">abx</span>
    </a>

    <nav class="nav-desktop">
      <a href="/" class:list={["nav-link", { active: isActive("/") }]}>home</a>
      <a href="/resume" class:list={["nav-link", { active: isActive("/resume") }]}>resume</a>
      <a href="/contact" class:list={["nav-link", { active: isActive("/contact") }]}>contact</a>
    </nav>

    <div class="nav-social">
      <a href="https://github.com/AbiXnash" target="_blank" rel="noreferrer" class="social-link" aria-label="GitHub">
