        </svg>
      </a>
      <a href="https://linkedin.com/in/abinash-selvarasu" target="_blank" rel="noreferrer" class="social-link" aria-label="LinkedIn">
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>

    <button class="mobile-menu-btn" aria-label="Toggle menu" id="mobileMenuBtn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
</header>

<div class="mobile-nav-overlay" id="mobileOverlay"></div>

<nav class="mobile-nav" id="mobileNav">
  <div class="mobile-nav-header">
    <span class="mobile-nav-brand">
      <span class="brand-mark">$</span>
      <span class="brand-name">abx</span>
    </span>
    <button class="mobile-nav-close" id="mobileNavClose" aria-label="Close menu">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  
  <div class="mobile-nav-links">
    <a href="/" class:list={["mobile-nav-link", { active: isActive("/") }]}>
      <span class="link-icon">~/</span>
      <span>home</span>
    </a>
    <a href="/resume" class:list={["mobile-nav-link", { active: isActive("/resume") }]}>
      <span class="link-icon">~/</span>
      <span>resume</span>
    </a>
    <a href="/contact" class:list={["mobile-nav-link", { active: isActive("/contact") }]}>
      <span class="link-icon">~/</span>
      <span>contact</span>
    </a>
  </div>

  <div class="mobile-nav-footer">
    <a href="https://github.com/AbiXnash" target="_blank" rel="noreferrer" class="mobile-nav-social">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2C6.48 2 2 6.58 2 12.28c0 4.52 2.87 8.36 6.84 9.72.5.1.68-.22.68-.48v-1.7c-2.78.62-3.37-1.4-3.37-1.4-.45-1.16-1.1-1.47-1.1-1.47-.9-.63.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.9 1.56 2.36 1.11 2.94.85.09-.67.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.32.1-2.75 0 0 .84-.28 2.75 1.05a9.4 9.4 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.43.2 2.49.1 2.75.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.78-4.57 5.03.36.32.68.94.68 1.9v2.82c0 .26.18.58.69.48A10.3 10.3 0 0 0 22 12.28C22 6.58 17.52 2 12 2z"/>
      </svg>
      <span>@AbiXnash</span>
    </a>
    <a href="https://linkedin.com/in/abinash-selvarasu" target="_blank" rel="noreferrer" class="mobile-nav-social">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      <span class="social-name">@abinash-selvarasu</span>
    </a>
  </div>
</nav>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem;
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .header-inner {
      padding: 1.5rem;
    }
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .logo-mark {
    font-family: "JetBrains Mono", monospace;
    color: var(--accent);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .logo-name {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
  }

  .nav-desktop {
    display: none;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .nav-desktop {
      display: flex;
    }
  }

  .nav-link {
    font-size: 0.875rem;
    color: var(--text-muted);
    transition: color 150ms ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
  }

  .nav-link.active {
    color: var(--accent);
  }

  .nav-social {
    display: none;
    gap: 0.5rem;
  }

  @media (min-width: 768px) {
    .nav-social {
      display: flex;
    }
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--text-muted);
    transition: color 150ms ease;
  }

  .social-link:hover {
    color: var(--text);
  }

  .social-link svg {
    width: 20px;
    height: 20px;
  }

  .mobile-menu-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    transition: all 150ms ease;
  }

  @media (min-width: 768px) {
    .mobile-menu-btn {
      display: none;
    }
  }

  .mobile-menu-btn:hover {
    border-color: var(--accent);
  }

  .mobile-menu-btn svg {
    width: 20px;
    height: 20px;
    color: var(--text-muted);
  }

  .mobile-nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 200;
    opacity: 0;
    transition: opacity 200ms ease;
  }

  .mobile-nav-overlay.open {
    display: block;
    opacity: 1;
  }

  .mobile-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--bg-elevated);
    border-top: 1px solid var(--border);
    border-radius: 20px 20px 0 0;
    padding: 1.5rem 2rem 2.5rem;
    z-index: 201;
    transform: translateY(100%);
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
    max-height: 70vh;
    overflow-y: auto;
  }

  .mobile-nav.open {
    transform: translateY(0);
  }

  .mobile-nav-handle {
    display: flex;
    justify-content: center;
    padding: 0.5rem 0 1rem;
  }

  .handle-bar {
    width: 40px;
    height: 4px;
    background: var(--border);
    border-radius: 2px;
  }

  .mobile-nav-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0.5rem;
  }

  .mobile-nav-brand {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .brand-mark {
    font-family: "JetBrains Mono", monospace;
    color: var(--accent);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .brand-name {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
  }

  .mobile-nav-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 50%;
    cursor: pointer;
    transition: all 150ms ease;
  }

  .mobile-nav-close:hover {
    border-color: var(--accent);
  }

  .mobile-nav-close svg {
    width: 20px;
    height: 20px;
    color: var(--text-muted);
    stroke-width: 2;
  }

  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 1.25rem;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.125rem 1.25rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    font-size: 1rem;
    color: var(--text-muted);
    transition: all 150ms ease;
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    border-color: var(--accent);
    color: var(--text);
  }

  .mobile-nav-link.active {
    color: var(--accent);
  }

  .mobile-nav-link.active .link-icon {
    color: var(--accent);
  }

  .link-icon {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .mobile-nav-footer {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .mobile-nav-social {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1.25rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text-muted);
    font-size: 0.8125rem;
    transition: all 150ms ease;
    min-width: 0;
  }

  .mobile-nav-social:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .mobile-nav-social svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .social-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>

<script>
  const btn = document.getElementById('mobileMenuBtn');
  const nav = document.getElementById('mobileNav');
  const overlay = document.getElementById('mobileOverlay');
  const closeBtn = document.getElementById('mobileNavClose');
  
  function openNav() {
    nav?.classList.add('open');
    overlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  
  function closeNav() {
    nav?.classList.remove('open');
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
  }
  
  btn?.addEventListener('click', openNav);
  closeBtn?.addEventListener('click', closeNav);
  overlay?.addEventListener('click', closeNav);
  
  nav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeNav);
  });
</script>
