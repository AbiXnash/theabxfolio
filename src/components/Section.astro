---
interface Props {
  title?: string;
  className?: string;
}

const { title, className = "" } = Astro.props;
---

<section class={`flex flex-col gap-8 ${className}`}>
  {title && (
    <h2 class="pixel-heading text-portfolio-accent text-xs sm:text-sm flex items-center gap-4">
      <span class="text-portfolio-muted text-[10px]">{"//"}</span> {title}
      <div class="h-[1px] flex-1 bg-portfolio-border ml-4"></div>
    </h2>
  )}
  <div class="flex flex-col gap-6">
    <slot />
  </div>
</section>
