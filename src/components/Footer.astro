---
const year = new Date().getFullYear();
---

<footer class="footer reveal">
  <div class="footer-inner container">
    <div class="footer-main">
      <div class="footer-copy-block">
        <span class="footer-kicker">Built with intent</span>
        <h2 class="footer-name">Abinash Selvarasu</h2>
        <p class="footer-note">
          Software engineer focused on payments, resilient systems, and practical product engineering.
        </p>
      </div>

      <div class="footer-meta">
        <nav class="footer-links" aria-label="Footer navigation">
          <a href="/" class="surface-link">home</a>
          <a href="/resume" class="surface-link">resume</a>
          <a href="/contact" class="surface-link">contact</a>
          <a href="https://github.com/AbiXnash" target="_blank" rel="noreferrer" class="surface-link">github</a>
        </nav>

        <div class="footer-stamp">
          <span class="mono footer-year">{year}</span>
          <span class="footer-role">Software Engineer</span>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 2.25rem 0 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin-top: auto;
    width: 100%;
  }

  .footer-inner {
    padding-top: 0.25rem;
  }

  .footer-main {
    display: grid;
    gap: 1.25rem;
    padding: 1.35rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
    background:
      radial-gradient(circle at top right, rgba(255, 107, 53, 0.12), transparent 30%),
      linear-gradient(135deg, rgba(255, 107, 53, 0.06), rgba(255, 255, 255, 0.015)),
      rgba(255, 255, 255, 0.01);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 16px 34px rgba(0, 0, 0, 0.14);
    transition:
      transform 220ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease;
  }

  .footer-main:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 107, 53, 0.16);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 20px 40px rgba(0, 0, 0, 0.18);
  }

  .footer-copy-block {
    display: grid;
    gap: 0.55rem;
  }

  .footer-kicker {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .footer-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
  }

  .footer-note {
    max-width: 50ch;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .footer-meta {
    display: grid;
    gap: 1rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .footer-stamp {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-year,
  .footer-role {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .mono {
    font-family: "JetBrains Mono", monospace;
  }

  @media (min-width: 900px) {
    .footer-main {
      grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.9fr);
      align-items: end;
    }
  }
</style>
