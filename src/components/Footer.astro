---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner container">
    <div class="footer-left">
      <span class="footer-name">Abinash Selvarasu</span>
      <span class="footer-role">Backend Engineer</span>
    </div>

    <nav class="footer-links" aria-label="Footer navigation">
      <a href="/">home</a>
      <a href="/resume">resume</a>
      <a href="/contact">contact</a>
      <a href="https://github.com/AbiXnash" target="_blank" rel="noreferrer">github</a>
    </nav>

    <div class="footer-copy">
      <span class="mono">{year}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
    margin-top: auto;
    width: 100%;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 480px) {
    .footer-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
    }
  }

  @media (min-width: 640px) {
    .footer-inner {
      gap: 2rem;
    }
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  @media (min-width: 480px) {
    .footer-left {
      flex-direction: row;
      align-items: center;
      gap: 1rem;
    }
  }

  .footer-name {
    font-weight: 600;
    font-size: 0.8125rem;
  }

  @media (min-width: 640px) {
    .footer-name {
      font-size: 0.875rem;
    }
  }

  .footer-role {
    color: var(--text-dim);
    font-size: 0.75rem;
  }

  @media (min-width: 640px) {
    .footer-role {
      font-size: 0.875rem;
    }
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
  }

  @media (min-width: 640px) {
    .footer-links {
      gap: 1.5rem;
    }
  }

  .footer-links a {
    color: var(--text-muted);
    font-size: 0.75rem;
    transition: color 150ms ease;
  }

  @media (min-width: 640px) {
    .footer-links a {
      font-size: 0.875rem;
    }
  }

  .footer-links a:hover {
    color: var(--text);
  }

  .footer-copy {
    color: var(--text-dim);
    font-size: 0.6875rem;
  }

  @media (min-width: 640px) {
    .footer-copy {
      font-size: 0.75rem;
    }
  }

  .mono {
    font-family: "JetBrains Mono", monospace;
  }
</style>
