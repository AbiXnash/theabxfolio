---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body class="bg-gruv-bg text-gruv-text min-h-screen antialiased">
    <!-- Personal Portfolio Navbar -->
    <nav
      class="bg-gruv-bg border-gruv-border/30 fixed top-0 right-0 left-0 z-50 h-16 border-b"
      transition:persist
    >
      <div
        class="mx-auto flex h-full max-w-6xl items-center justify-between px-6"
      >
        <div class="flex items-center gap-4">
          <a href="/" class="group flex items-center gap-2">
            <span
              class="text-gruv-text group-hover:text-gruv-orange text-lg font-bold tracking-tight transition-colors"
              >abx <span class="text-gruv-muted font-normal">//</span> selvarasu</span
            >
          </a>
          <div class="bg-gruv-border/50 hidden h-4 w-[1px] sm:block"></div>
          <span
            class="text-gruv-muted hidden text-[10px] font-bold tracking-widest uppercase sm:block"
          >
            Backend Engineer
          </span>
        </div>

        <!-- Desktop Links -->
        <div
          class="hidden items-center gap-8 text-xs font-bold tracking-widest uppercase md:flex"
        >
          <a
            href="#experience"
            data-astro-prefetch
            class="text-gruv-muted hover:text-gruv-text transition-colors"
            >Work</a
          >
          <a
            href="#projects"
            data-astro-prefetch
            class="text-gruv-muted hover:text-gruv-text transition-colors"
            >Lab</a
          >
          <a
            href="#research"
            data-astro-prefetch
            class="text-gruv-muted hover:text-gruv-text transition-colors"
            >Notes</a
          >
          <a
            href="mailto:abinash@theabx.in"
            class="text-gruv-orange flex items-center gap-2 transition-all hover:brightness-125"
          >
            Say Hello
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              ><line x1="22" y1="2" x2="11" y2="13"></line><polyline
                points="22 2 15 22 11 13 2 9 22 2"></polyline></svg
            >
          </a>
        </div>

        <!-- Mobile Toggle -->
        <button id="menu-toggle" class="text-gruv-text p-2 md:hidden" aria-label="Toggle Menu">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><line x1="3" y1="12" x2="21" y2="12"></line><line
              x1="3"
              y1="6"
              x2="21"
              y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
          >
        </button>
      </div>
    </nav>

    <!-- Mobile Bottom Drawer Overlay -->
    <div id="mobile-overlay" class="fixed inset-0 z-[60] hidden bg-black/60 backdrop-blur-sm transition-opacity duration-300 md:hidden"></div>

    <!-- Mobile Bottom Drawer -->
    <div
      id="mobile-menu"
      class="bg-gruv-surface border-gruv-border fixed right-0 bottom-0 left-0 z-[70] flex translate-y-full flex-col gap-6 border-t rounded-t-[2.5rem] p-8 transition-transform duration-300 ease-out md:hidden"
    >
        <!-- Drawer Handle -->
        <div class="mx-auto h-1.5 w-12 rounded-full bg-gruv-border mb-2"></div>
        
        <div class="flex flex-col gap-8 items-center text-center">
            <a href="#experience" class="mobile-link text-2xl font-black tracking-tightest uppercase italic">Work</a>
            <a href="#projects" class="mobile-link text-2xl font-black tracking-tightest uppercase italic">Lab</a>
            <a href="#research" class="mobile-link text-2xl font-black tracking-tightest uppercase italic">Notes</a>
            <a
              href="mailto:abinash@theabx.in"
              class="bg-gruv-orange text-gruv-bg w-full rounded-full px-5 py-4 text-center text-lg font-bold shadow-premium"
              >Say Hello</a
            >
        </div>
    </div>

    <slot />

    <footer class="border-gruv-border/30 mt-20 border-t px-6 py-20">
      <div
        class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-10 md:flex-row"
      >
        <div class="flex flex-col gap-2 text-center md:text-left">
          <div class="text-2xl font-bold tracking-tighter">
            Let's build something resilient.
          </div>
          <p class="text-gruv-muted">
            Available for high-stakes backend engineering roles.
          </p>
        </div>
        <div class="flex gap-6">
          <a
            href="https://github.com/AbiXnash"
            target="_blank"
            class="text-gruv-muted hover:text-gruv-orange transition-colors"
            >GitHub</a
          >
          <a
            href="https://instagram.com/abx.engg"
            target="_blank"
            class="text-gruv-muted hover:text-gruv-orange transition-colors"
            >Instagram</a
          >
          <a
            href="mailto:abinash@theabx.in"
            class="text-gruv-muted hover:text-gruv-orange transition-colors"
            >Email</a
          >
        </div>
      </div>
      <div
        class="text-gruv-muted mx-auto mt-20 max-w-6xl text-center text-xs tracking-widest uppercase opacity-50"
      >
        © {new Date().getFullYear()} Abinash S. — SYSTEM_STATUS: OPERATIONAL
      </div>
    </footer>

    <script>
      function setup() {
        const toggle = document.getElementById("menu-toggle");
        const menu = document.getElementById("mobile-menu");
        const overlay = document.getElementById("mobile-overlay");
        const links = document.querySelectorAll(".mobile-link");

        function toggleMenu() {
            const isOpen = menu?.classList.contains("translate-y-0");
            
            if (isOpen) {
                // Close
                menu?.classList.remove("translate-y-0");
                menu?.classList.add("translate-y-full");
                overlay?.classList.add("hidden");
                document.body.style.overflow = "";
            } else {
                // Open
                menu?.classList.remove("translate-y-full");
                menu?.classList.add("translate-y-0");
                overlay?.classList.remove("hidden");
                document.body.style.overflow = "hidden"; // Prevent background scroll
            }
        }

        toggle?.addEventListener("click", toggleMenu);
        overlay?.addEventListener("click", toggleMenu);
        
        links.forEach((l) =>
          l.addEventListener("click", toggleMenu),
        );

        // Scroll Reveal Observer
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("active");
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
        );

        document
          .querySelectorAll(".reveal")
          .forEach((el) => observer.observe(el));
      }

      // Initial setup
      setup();

      // Re-setup on view transitions
      document.addEventListener("astro:after-swap", setup);
    </script>
  </body>
</html>
