---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const {
  title = "Abinash Selvarasu",
  description = "Backend Engineer specializing in payments, security, and resilient systems. Building production-grade platforms with clean architecture.",
  canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://theabx.in"),
  ogImage = "/arch-logo.svg",
  pageType = "website",
} = Astro.props;

const siteName = "Abinash Selvarasu";
const siteUrl = "https://theabx.in";
const twitterHandle = "@AbiXnash";
const linkedInUrl = "https://linkedin.com/in/abinash-selvarasu";
const githubUrl = "https://github.com/AbiXnash";
const authorName = "Abinash Selvarasu";
const authorEmail = "abinash@theabx.in";
const organizationName = "Mindgate Solutions";
const organizationUrl = "https://www.mindgate.solutions";
---

<!doctype html>
<html lang="en" itemscope itemtype="https://schema.org/WebPage">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={siteName} />

    <!-- Primary Meta Tags -->
    <title itemprop="name">{title}</title>
    <meta name="title" content={title} />
    <meta name="description" itemprop="description" content={description} />
    <meta name="author" content={authorName} />
    <meta name="creator" content={authorName} />
    <meta name="publisher" content={organizationName} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#ff6b35" />
    <meta name="color-scheme" content="dark" />
    <meta name="rating" content="general" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="identifier-URL" content={canonicalURL} />

    <!-- Google Indexing -->
    <meta name="googlebot" content="index, follow" />
    <meta name="googlebot-news" content="index, follow" />
    <meta name="google-site-verification" content="google-site-verification-code" />

    <!-- Bing Indexing -->
    <meta name="msvalidate.01" content="bing-site-verification-code" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon & Icons -->
    <link rel="icon" type="image/svg+xml" href="/arch-logo.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/arch-logo.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/arch-logo.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/arch-logo.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="msapplication-TileColor" content="#0f0f0f" />
    <meta name="msapplication-TileImage" content="/arch-logo.svg" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonicalURL} itemprop="url" />
    <meta property="og:title" content={title} itemprop="name" />
    <meta property="og:description" content={description} itemprop="description" />
    <meta property="og:image" content={ogImage} itemprop="image" />
    <meta property="og:image:url" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:site_name" content={siteName} itemprop="name" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="en_GB" />

    <!-- Facebook -->
    <meta property="fb:app_id" content="facebook-app-id" />
    <meta property="fb:admins" content="facebook-admin-id" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:creator" content={twitterHandle} />
    <meta name="twitter:site" content={twitterHandle} />
    <meta name="twitter:label1" content="Role" />
    <meta name="twitter:data1" content="Backend Engineer" />
    <meta name="twitter:label2" content="Location" />
    <meta name="twitter:data2" content="India" />

    <!-- LinkedIn -->
    <meta property="article:author" content={linkedInUrl} />
    <meta property="article:publisher" content={organizationUrl} />

    <!-- Pinterest -->
    <meta name="pinterest-rich-pin" content="true" />

    <!-- WhatsApp -->
    <meta property="og:image:alt" content={title} />

    <!-- Additional SEO Meta Tags -->
    <meta name="coverage" content="Worldwide" />
    <meta name="distribution" content="Global" />
    <meta name="revisit-after" content="7 days" />
    <meta name="expires" content="never" />
    <meta name="language" content="EN" />
    <meta name="reply-to" content={authorEmail} />
    <meta name="abstract" content={description} />
    <meta name="topic" content="Backend Engineering, Payments, Security" />
    <meta name="summary" content={description} />
    <meta name="Classification" content="Personal Portfolio" />
    <meta name="keywords" content="Backend Engineer, Payments, Security, Microservices, Java, Spring Boot, API Development, PostgreSQL, Portfolio, Abinash Selvarasu" />

    <!-- Author Meta Tags -->
    <meta name="author" content={authorName} itemprop="author" itemscope itemtype="https://schema.org/Person" />
    <link rel="author" href={siteUrl} />
    <link rel="me" href={githubUrl} />
    <link rel="me" href={linkedInUrl} />

    <!-- Preconnect to external domains for fast loading -->
    <link rel="preconnect" href="https://api.github.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- DNS prefetch for additional domains -->
    <link rel="dns-prefetch" href="https://api.github.com" />

    <!-- Google Fonts with display swap for performance -->
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    </noscript>

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Webfeeds -->
    <link rel="webfeed" type="application/rss+xml" title={siteName} href="/rss.xml" />

    <!-- JSON-LD Structured Data - Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": organizationName,
      "url": organizationUrl,
      "logo": ogImage,
      "description": "Leading payment solutions company in India",
      "sameAs": [
        linkedInUrl,
        "https://x.com/mindgate"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+91-XXX-XXX-XXXX",
        "contactType": "customer service"
      }
    })} />

    <!-- JSON-LD Structured Data - Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": authorName,
      "alternateName": ["Abinash S", "AbiXnash"],
      "url": siteUrl,
      "image": ogImage,
      "email": authorEmail,
      "jobTitle": "Backend Engineer",
      "description": description,
      "knowsAbout": ["Java", "Spring Boot", "Microservices", "Payments", "Security", "APIs", "Backend Development"],
      "skills": ["Java", "Spring Boot", "Microservices", "PostgreSQL", "OracleDB", "Payment Systems", "REST APIs"],
      "worksFor": {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        "name": organizationName,
        "url": organizationUrl
      },
      "sameAs": [
        githubUrl,
        linkedInUrl,
        "https://x.com/theabxguy",
        "https://instagram.com/_abixnash_"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "IN",
        "addressRegion": "India"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": canonicalURL,
        "url": canonicalURL,
        "name": title,
        "description": description
      }
    })} />

    <!-- JSON-LD Structured Data - Website -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": siteName,
      "description": description,
      "publisher": {
        "@id": `${siteUrl}/#person`
      },
      "inLanguage": "en-US",
      "isAccessibleForFree": "True",
      "type": "WebSite",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteUrl}/?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- JSON-LD Structured Data - ProfessionalService -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#professional-service`,
      "name": siteName,
      "description": description,
      "url": siteUrl,
      "image": ogImage,
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "IN"
      },
      "priceRange": "$$",
      "openingHours": "Mo-Fr 09:00-18:00",
      "areaServed": "Worldwide",
      "provider": {
        "@id": `${siteUrl}/#organization`
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Backend Development",
              "description": "Java, Spring Boot, Microservices architecture"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Payment Systems",
              "description": "Secure payment processing and integration"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "API Development",
              "description": "RESTful APIs and system integration"
            }
          }
        ]
      }
    })} />

    <!-- JSON-LD Structured Data - BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "@id": `${canonicalURL}/#breadcrumb`,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": title.split(" | ")[1] || "Portfolio",
          "item": canonicalURL
        }
      ]
    })} />

    <!-- JSON-LD FAQ for AEO (Answer Engine Optimization) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Who is Abinash Selvarasu?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Abinash Selvarasu is a Backend Engineer specializing in payments, security, and resilient systems. He works with Java, Spring Boot, microservices, and payment platforms."
          }
        },
        {
          "@type": "Question",
          "name": "What technologies does Abinash work with?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Abinash works with Java, Spring Boot, microservices architecture, OracleDB, PostgreSQL, payment systems, and API development."
          }
        },
        {
          "@type": "Question",
          "name": "Where does Abinash work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Abinash currently works at Mindgate Solutions, focusing on banking and payment infrastructure."
          }
        },
        {
          "@type": "Question",
          "name": "How can I contact Abinash Selvarasu?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can contact Abinash through the contact form on his portfolio website or via email at abinash@theabx.in"
          }
        }
      ]
    })} />

    <!-- Knowledge Graph -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": `${siteUrl}/#organization`,
          "name": organizationName,
          "url": organizationUrl
        },
        {
          "@type": "Person",
          "@id": `${siteUrl}/#person`,
          "name": authorName,
          "url": siteUrl
        },
        {
          "@type": "WebSite",
          "@id": `${siteUrl}/#website`,
          "url": siteUrl,
          "name": siteName
        },
        {
          "@type": "WebPage",
          "@id": `${canonicalURL}/#webpage`,
          "url": canonicalURL,
          "name": title
        }
      ]
    })} />
  </head>

  <body itemscope itemtype="https://schema.org/WebPage">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />

    <main id="main-content" itemprop="mainContentOfPage" role="main">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style>
  :global(body) {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  main {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  @media (min-width: 640px) {
    main {
      padding-left: 2rem;
      padding-right: 2rem;
    }
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    background: var(--accent);
    color: #000;
    padding: 0.5rem 1rem;
    z-index: 1000;
    transition: top 200ms ease;
  }

  .skip-link:focus {
    top: 0;
  }
</style>
