---
import BaseLayout from "../layouts/BaseLayout.astro";
import resumeData from "../data/resume.json";

const { work, projects, research, education } = resumeData;
---

<BaseLayout title="Abinash S. | Software Engineer">
  <!-- Hero Section -->
  <header
    class="flex flex-col-reverse gap-8 pt-12 pb-8 sm:flex-row sm:items-center sm:justify-between"
  >
    <div class="flex flex-col gap-6">
      <h1
        class="text-apple-text max-w-3xl text-5xl leading-tight font-semibold tracking-tight sm:text-7xl"
      >
        Software Engineer building resilient systems.
      </h1>
      <p
        class="text-apple-textMuted max-w-2xl text-xl leading-relaxed font-medium tracking-tight sm:text-2xl"
      >
        Specializing in payments, security, and high-volume banking workflows
        under strict production constraints.
      </p>
      <div class="mt-4 flex gap-4">
        <a
          href="mailto:abinash@theabx.in"
          class="bg-apple-text text-apple-bg rounded-full px-6 py-3 text-sm font-medium transition-transform duration-300 hover:scale-105"
        >
          Contact Me
        </a>
        <a
          href="https://github.com/AbiXnash"
          target="_blank"
          class="bg-apple-surface border-apple-border text-apple-text hover:bg-apple-surfaceHover rounded-full border px-6 py-3 text-sm font-medium transition-colors duration-300"
        >
          GitHub
        </a>
      </div>
    </div>
    <div class="flex-shrink-0">
      <div
        class="border-apple-border/50 relative h-32 w-32 overflow-hidden rounded-full border-4 sm:h-48 sm:w-48"
      >
        <img
          src="/profile.jpg"
          alt="Abinash Selvarasu"
          class="h-full w-full object-cover transition-transform duration-500 hover:scale-110"
        />
      </div>
    </div>
  </header>

  <!-- Experience -->
  <section id="experience" class="flex scroll-mt-24 flex-col gap-8">
    <h2 class="text-2xl font-semibold tracking-tight">Experience</h2>
    <div class="flex flex-col gap-6">
      {
        work.items.map((item) => (
          <div class="bg-apple-surface border-apple-border/50 shadow-apple hover:shadow-apple-hover rounded-3xl border p-8 transition-shadow duration-300 sm:p-10">
            <div class="mb-4 flex flex-col justify-between gap-2 sm:flex-row sm:items-baseline">
              <h3 class="text-apple-text text-xl font-semibold">
                {item.title}
              </h3>
              <span class="text-apple-textMuted text-sm font-medium">
                {item.meta}
              </span>
            </div>
            <p class="text-apple-text mb-6 text-lg leading-relaxed font-medium">
              {item.intro}
            </p>
            <ul class="flex flex-col gap-3">
              {item.details
                .split("\n")
                .filter((line) => line.startsWith("-"))
                .map((line) => (
                  <li class="text-apple-textMuted flex items-start gap-3 text-base">
                    <span class="text-apple-accent mt-1 flex-shrink-0 opacity-70">
                      <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                    </span>
                    <span class="leading-relaxed">
                      {line.replace("- ", "")}
                    </span>
                  </li>
                ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="flex scroll-mt-24 flex-col gap-8">
    <h2 class="text-2xl font-semibold tracking-tight">Selected Projects</h2>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        projects.items.slice(0, 4).map((item) => (
          <a
            href={item.github}
            target="_blank"
            class="group bg-apple-surface border-apple-border/50 shadow-apple hover:shadow-apple-hover block rounded-3xl border p-8 transition-all duration-300 hover:-translate-y-1"
          >
            <div class="flex h-full flex-col justify-between gap-8">
              <div>
                <div class="text-apple-accent mb-3 text-xs font-semibold tracking-wider uppercase">
                  {item.category}
                </div>
                <h3 class="text-apple-text group-hover:text-apple-accent mb-3 text-xl font-semibold transition-colors">
                  {item.title}
                </h3>
                <p class="text-apple-textMuted text-base leading-relaxed">
                  {item.intro}
                </p>
              </div>
              <div class="text-apple-textMuted group-hover:text-apple-accent flex items-center gap-1 text-sm font-medium transition-colors">
                View Project
                <svg
                  class="-translate-x-2 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </>
                </svg>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Research & Papers -->
  <section id="research" class="flex scroll-mt-24 flex-col gap-8">
    <h2 class="text-2xl font-semibold tracking-tight">Research & Papers</h2>
    <div class="flex flex-col gap-4">
      {
        research.items.map((item) => (
          <a
            href={item.github}
            target="_blank"
            class="group bg-apple-surface border-apple-border/50 shadow-apple hover:shadow-apple-hover flex flex-col justify-between gap-4 rounded-2xl border p-6 transition-all duration-300 sm:flex-row sm:items-center"
          >
            <div class="flex flex-col gap-2">
              <h3 class="text-apple-text group-hover:text-apple-accent text-lg font-semibold transition-colors">
                {item.title}
              </h3>
              <p class="text-apple-textMuted text-sm">{item.intro}</p>
            </div>
            <div class="text-apple-textMuted bg-apple-surfaceHover shrink-0 rounded-full px-3 py-1.5 text-xs font-medium">
              {item.meta.split("·")[0].trim()}
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Education -->
  <section class="flex flex-col gap-8">
    <h2 class="text-2xl font-semibold tracking-tight">Education</h2>
    <div
      class="bg-apple-surface border-apple-border/50 shadow-apple rounded-3xl border p-8"
    >
      {
        education.items.map((item) => (
          <div class="flex flex-col gap-2">
            <div class="flex flex-col justify-between gap-1 sm:flex-row sm:items-baseline">
              <h3 class="text-apple-text text-xl font-semibold">
                {item.title}
              </h3>
              <span class="text-apple-textMuted text-sm font-medium">
                {item.meta}
              </span>
            </div>
            <p class="text-apple-textMuted text-base">{item.intro}</p>
          </div>
        ))
      }
    </div>
  </section>

  <footer
    class="border-apple-border/50 text-apple-textMuted mt-12 flex flex-col items-center justify-between gap-4 border-t pt-8 text-sm font-medium sm:flex-row"
  >
    <p>© {new Date().getFullYear()} Abinash S.</p>
    <div class="flex gap-4">
      <a
        href="https://github.com/AbiXnash"
        class="hover:text-apple-text transition-colors">GitHub</a
      >
      <a
        href="mailto:abinash@theabx.in"
        class="hover:text-apple-text transition-colors">Email</a
      >
    </div>
  </footer>
</BaseLayout>
