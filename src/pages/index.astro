---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Use getEntry to fetch the single resume data object
const resumeEntry = await getEntry('resume', 'resume');

if (!resumeEntry) {
    throw new Error('Could not find resume data in content collection. ID used: resume');
}

const { work, projects, research } = resumeEntry.data;

// Order research by year (descending)
const sortedResearch = [...research.items].sort((a, b) => {
    const yearA = parseInt(a.meta.match(/\d{4}/)?.[0] || '0');
    const yearB = parseInt(b.meta.match(/\d{4}/)?.[0] || '0');
    return yearB - yearA;
});
---

<BaseLayout title="Abinash Selvarasu | Backend Engineer">
  
  <main class="max-w-6xl mx-auto px-6 pt-32 sm:pt-48 flex flex-col gap-32 sm:gap-48">
    
    <!-- Hero Section -->
    <section class="flex flex-col items-center text-center gap-12 reveal relative">
      <!-- Glow background -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[150%] h-[150%] bg-gruv-orange/5 blur-[120px] rounded-full pointer-events-none -z-10"></div>
      
      <div class="flex flex-col items-center gap-10 max-w-4xl">
        <div class="relative group">
            <div class="pixel-pet scale-125 mb-4 group-hover:scale-150 transition-transform duration-500"></div>
            <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-12 h-2 bg-black/20 blur-md rounded-full"></div>
        </div>

        <div class="flex flex-col gap-6">
            <h2 class="text-gruv-orange font-bold uppercase tracking-[0.3em] text-[10px] sm:text-xs flex items-center justify-center gap-4">
                <span class="w-8 h-[1px] bg-gruv-orange/30"></span> 
                Available for Innovation 
                <span class="w-8 h-[1px] bg-gruv-orange/30"></span>
            </h2>
            <h1 class="text-6xl sm:text-[10rem] font-extrabold tracking-[calc(-0.04em)] leading-[0.85] text-gruv-text italic">
                CRAFTING <br class="hidden sm:block" /> <span class="text-gruv-orange text-shadow-glow">SYSTEMS.</span>
            </h1>
        </div>

        <p class="text-xl sm:text-3xl text-gruv-muted leading-relaxed font-medium max-w-2xl tracking-tight">
            Software Engineer specializing in <span class="text-gruv-text">high-stakes</span> backend architecture and <span class="text-gruv-text">resilient</span> payment workflows.
        </p>

        <div class="flex flex-col sm:flex-row gap-8 items-center mt-4">
            <a href="mailto:abinash@theabx.in" class="bg-gruv-text text-gruv-bg px-10 py-5 rounded-full font-bold text-xl hover:scale-105 hover:bg-gruv-orange transition-all duration-500 shadow-premium">
                Initialize Contact
            </a>
            <a href="#projects" class="text-gruv-muted font-bold text-lg hover:text-gruv-orange transition-colors flex items-center gap-2 group">
                Review Artifacts <svg class="group-hover:translate-x-1 transition-transform" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section id="experience" class="flex flex-col gap-12 sm:gap-20 scroll-mt-32 reveal">
        <div class="flex flex-col gap-4">
            <h2 class="text-gruv-orange font-bold uppercase tracking-widest text-xs sm:text-sm">Work Experience</h2>
            <h3 class="text-4xl sm:text-6xl font-extrabold tracking-tighter">Current Quests.</h3>
        </div>
        <div class="flex flex-col gap-8">
            {work.items.map(item => (
                <ExperienceCard {...item} />
            ))}
        </div>
    </section>

    <!-- Projects -->
    <section id="projects" class="flex flex-col gap-12 sm:gap-20 scroll-mt-32 reveal">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
            <div class="flex flex-col gap-4">
                <h2 class="text-gruv-orange font-bold uppercase tracking-widest text-xs sm:text-sm">Engineering Registry</h2>
                <h3 class="text-4xl sm:text-6xl font-extrabold tracking-tighter">Selected Artifacts.</h3>
            </div>
            <a href="https://github.com/AbiXnash" target="_blank" class="text-gruv-muted font-bold hover:text-gruv-orange transition-colors flex items-center gap-2 text-lg">
                Full Registry (GitHub) <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
        </div>
        <!-- Mobile scroll control: horizontal carousel -->
        <div class="flex md:grid md:grid-cols-2 gap-8 overflow-x-auto md:overflow-visible pb-10 md:pb-0 no-scrollbar snap-x snap-mandatory">
            {projects.items.map(item => (
                <div class="min-w-[85vw] md:min-w-0 snap-center">
                    <ProjectCard {...item} />
                </div>
            ))}
        </div>
    </section>

    <!-- Research -->
    <section id="research" class="flex flex-col gap-12 sm:gap-20 scroll-mt-32 reveal">
        <div class="flex flex-col gap-4">
            <h2 class="text-gruv-orange font-bold uppercase tracking-widest text-xs sm:text-sm">Academic Lore</h2>
            <h3 class="text-4xl sm:text-6xl font-extrabold tracking-tighter">Applied Science.</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {sortedResearch.map(item => (
                <div class="bg-gruv-surface/40 border border-gruv-border/30 rounded-[2rem] p-8 flex flex-col justify-between gap-6 hover:border-gruv-blue/50 transition-colors group">
                    <div class="flex flex-col gap-4">
                        <div class="text-gruv-blue font-bold text-[10px] uppercase tracking-widest opacity-60">Research Paper</div>
                        <h4 class="text-xl font-bold tracking-tight group-hover:text-gruv-blue transition-colors leading-tight">{item.title}</h4>
                        <p class="text-sm text-gruv-muted leading-relaxed line-clamp-3">{item.intro}</p>
                    </div>
                    <div class="flex items-center justify-between mt-4">
                        <span class="text-xs font-medium text-gruv-muted">{item.meta.split('·')[0].trim()}</span>
                        <a href={item.github} target="_blank" class="w-10 h-10 rounded-full bg-gruv-bg flex items-center justify-center text-gruv-muted hover:text-gruv-blue transition-colors">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- Education Replacement: Technical Arsenal -->
    <section class="flex flex-col gap-12 sm:gap-20 reveal mb-20">
        <div class="flex flex-col gap-4 text-center items-center">
            <h2 class="text-gruv-orange font-bold uppercase tracking-widest text-xs sm:text-sm">Arsenal</h2>
            <h3 class="text-4xl sm:text-6xl font-extrabold tracking-tighter">System Stack.</h3>
        </div>
        <div class="max-w-4xl mx-auto w-full bg-gruv-surface/50 border border-gruv-border/30 rounded-apple p-10 sm:p-16 flex flex-col sm:flex-row items-center justify-between gap-10">
            <div class="flex flex-col gap-8 text-center sm:text-left flex-1">
                <div class="flex flex-col gap-2">
                    <div class="text-gruv-orange font-bold text-lg uppercase tracking-widest leading-none">Core Foundations</div>
                    <h4 class="text-3xl sm:text-4xl font-extrabold tracking-tighter">Java & Go Performance</h4>
                </div>
                <div class="flex flex-wrap justify-center sm:justify-start gap-3">
                    {['Spring Boot', 'PostgreSQL', 'Microservices', 'Distributed Systems', 'Astro', 'Bun', 'TypeScript'].map(tech => (
                        <span class="px-5 py-2.5 bg-gruv-bg rounded-xl font-mono text-sm border border-gruv-border/50 text-gruv-muted hover:text-gruv-orange hover:border-gruv-orange transition-all duration-300 cursor-default">
                            {tech}
                        </span>
                    ))}
                </div>
            </div>
            <div class="w-32 h-32 bg-gruv-border/30 rounded-full flex items-center justify-center shrink-0 animate-pulse relative">
                <div class="absolute inset-0 bg-gruv-orange/20 blur-xl rounded-full"></div>
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gruv-orange relative z-10"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
            </div>
        </div>
    </section>

  </main>
</BaseLayout>
