---
import BaseLayout from "../layouts/BaseLayout.astro";
import DialogueBox from "../components/DialogueBox.astro";
import resumeData from "../data/resume.json";

const { work, projects, research, education } = resumeData;
---

<BaseLayout title="ABX.folio - Player 1 Start">
  <!-- Header / Hero -->
  <div class="mt-12 mb-8 flex flex-col items-center gap-4">
    <div class="avatar-walk"></div>
    <div class="text-center">
      <h1 class="text-game-primary typewriter mb-2 text-xl sm:text-2xl">
        ABINASH S.
      </h1>
      <p class="text-game-secondary text-xs uppercase sm:text-sm">
        Lv. 99 Backend Engineer
      </p>
    </div>
  </div>

  <DialogueBox title="Intro">
    <p class="text-game-secondary mb-2">* Player 1 has entered the server.</p>
    <p>
      Software Engineer specializing in payments, security, and resilient
      systems. Building high-volume banking workflows and transaction-heavy
      payment systems under strict production constraints.
    </p>
  </DialogueBox>

  <DialogueBox title="Current Quests (Work)">
    {
      work.items.map((item) => (
        <div class="mb-6 last:mb-0">
          <h3 class="text-game-primary mb-1">&gt; {item.title}</h3>
          <p class="text-game-secondary mb-2 text-[10px] uppercase sm:text-xs">
            {item.meta}
          </p>
          <p class="mb-4">{item.intro}</p>
          <ul class="list-none space-y-2 pl-2 sm:pl-4">
            {item.details
              .split("\n")
              .filter((line) => line.startsWith("-"))
              .map((line) => (
                <li class="before:text-game-secondary flex items-start before:mr-2 before:content-['*']">
                  <span class="flex-1">{line.replace("- ", "")}</span>
                </li>
              ))}
          </ul>
        </div>
      ))
    }
  </DialogueBox>

  <DialogueBox title="Inventory (Projects)">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-6">
      {
        projects.items.slice(0, 4).map((item) => (
          <div class="border-game-border border-2 border-dashed p-3 transition-all hover:border-solid">
            <h3 class="text-game-primary mb-1 text-xs sm:text-sm">
              <a
                href={item.github}
                target="_blank"
                class="hover:text-game-text hover:bg-game-primary -ml-1 block truncate px-1 transition-colors"
              >
                {item.title}
              </a>
            </h3>
            <p class="text-game-secondary mb-2 text-[10px]">{item.category}</p>
            <p class="text-[10px] leading-relaxed sm:text-xs">{item.intro}</p>
          </div>
        ))
      }
    </div>
  </DialogueBox>

  <DialogueBox title="Lore (Research)">
    <div class="flex flex-col gap-4">
      {
        research.items.slice(0, 2).map((item) => (
          <div class="border-game-secondary border-l-2 pl-3">
            <h3 class="text-game-primary mb-1 text-xs sm:text-sm">
              ? {item.title}
            </h3>
            <p class="text-[10px] sm:text-xs">{item.intro}</p>
          </div>
        ))
      }
    </div>
  </DialogueBox>

  <DialogueBox title="Training (Education)">
    {
      education.items.map((item) => (
        <div>
          <h3 class="text-game-primary mb-1 text-xs sm:text-sm">
            ^ {item.title}
          </h3>
          <p class="text-game-secondary mb-2 text-[10px]">{item.meta}</p>
          <p class="text-[10px] sm:text-xs">{item.intro}</p>
        </div>
      ))
    }
  </DialogueBox>

  <div class="mt-8 mb-12 text-center">
    <a
      href="mailto:abinash@theabx.in"
      class="pixel-border hover:bg-game-text hover:text-game-bg inline-block cursor-pointer px-6 py-3 text-xs uppercase transition-colors sm:text-sm"
    >
      Connect P2 -&gt;
    </a>
  </div>
</BaseLayout>
