---
import BaseLayout from '../layouts/BaseLayout.astro';
import resumeData from '../data/resume.json';

const { work, projects, research, education } = resumeData;
---

<BaseLayout title="abx@server:~">
  
  <div class="mb-4">
    <span class="text-term-prompt font-bold">abx@server</span>:<span class="text-term-path font-bold">~</span>$ <span class="text-term-command font-bold">./resume.sh</span>
  </div>

  <!-- Hero / Intro -->
  <div><span class="text-term-muted">Loading profile data... OK.</span></div>
  <div class="mt-4">
    <div class="font-bold text-lg text-term-text">ABINASH SELVARASU</div>
    <div class="text-term-muted">Software Engineer building resilient systems.</div>
    <div class="text-term-muted">Specializing in payments, security, and high-volume banking workflows.</div>
  </div>
  
  <div class="mt-4">
    <div>[+] Links:</div>
    <div class="indent-1">
      <div><span class="text-term-muted">GitHub:</span> <a href="https://github.com/AbiXnash" target="_blank" class="term-link">github.com/AbiXnash</a></div>
      <div><span class="text-term-muted">Email:</span> <a href="mailto:abinash@theabx.in" class="term-link">abinash@theabx.in</a></div>
    </div>
  </div>

  <!-- Work Experience -->
  <div class="mt-8 mb-4 text-term-accent font-bold">==> Loading Work Experience</div>
  <div class="flex flex-col gap-6">
    {work.items.map(item => (
      <div>
        <div class="font-bold text-term-text">[+] {item.title} <span class="text-term-muted font-normal">({item.meta})</span></div>
        <div class="indent-1">
          <div class="mb-2 text-term-muted">{item.intro}</div>
          <div class="flex flex-col gap-1">
            {item.details.split('\n').filter(line => line.startsWith('-')).map(line => (
               <div><span class="text-term-prompt">-</span> {line.replace('- ', '')}</div>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Projects -->
  <div class="mt-8 mb-4 text-term-accent font-bold">==> Fetching Projects from Registry</div>
  <div class="flex flex-col gap-6">
    {projects.items.map(item => (
      <div>
        <div class="font-bold text-term-text">
            [+] {item.title} 
            <span class="text-term-muted font-normal">[{item.category}]</span>
        </div>
        <div class="indent-1">
          <div class="text-term-text mb-1">{item.intro}</div>
          <div class="text-term-muted mb-1">{item.details.split('\n')[0]}</div>
          <div><a href={item.github} target="_blank" class="term-link">-> source code</a></div>
        </div>
      </div>
    ))}
  </div>

  <!-- Research -->
  <div class="mt-8 mb-4 text-term-accent font-bold">==> Compiling Research Papers</div>
  <div class="flex flex-col gap-6">
    {research.items.map(item => (
      <div>
        <div class="font-bold text-term-text">[+] {item.title}</div>
        <div class="indent-1">
          <div class="text-term-muted mb-1">{item.meta}</div>
          <div class="text-term-text mb-1">{item.intro}</div>
          <div><a href={item.github} target="_blank" class="term-link">-> read paper</a></div>
        </div>
      </div>
    ))}
  </div>

  <!-- Education -->
  <div class="mt-8 mb-4 text-term-accent font-bold">==> Verifying Academic Credentials</div>
  <div class="flex flex-col gap-4">
    {education.items.map(item => (
      <div>
        <div class="font-bold text-term-text">[+] {item.title}</div>
        <div class="indent-1">
          <div class="text-term-muted mb-1">{item.meta}</div>
          <div class="text-term-text">{item.intro}</div>
        </div>
      </div>
    ))}
  </div>

  <!-- End of Script -->
  <div class="mt-8 mb-4">
    <span class="text-term-muted">Execution completed. Time elapsed: 0.42s</span>
  </div>
  
  <div>
    <span class="text-term-prompt font-bold">abx@server</span>:<span class="text-term-path font-bold">~</span>$ <span class="cursor"></span>
  </div>

</BaseLayout>
