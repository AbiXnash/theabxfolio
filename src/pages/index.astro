---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Use getEntry to fetch the single resume data object
const resumeEntry = await getEntry('resume', 'resume');

if (!resumeEntry) {
    throw new Error('Could not find resume data in content collection. ID used: resume');
}

const { work, projects, research } = resumeEntry.data;

// Order research by year (descending)
const sortedResearch = [...research.items].sort((a, b) => {
    const yearA = parseInt(a.meta.match(/\d{4}/)?.[0] || '0');
    const yearB = parseInt(b.meta.match(/\d{4}/)?.[0] || '0');
    return yearB - yearA;
});
---

<BaseLayout title="Abinash Selvarasu | Backend Engineer">
  
  <main class="max-w-6xl mx-auto px-6 pt-20 sm:pt-48 flex flex-col gap-16 sm:gap-48">
    
    <!-- Personal Hero Section -->
    <section class="flex flex-col items-center text-center gap-10 reveal relative pt-8 sm:pt-0">
      
      <div class="flex flex-col items-center gap-8 max-w-4xl">
        <div class="flex flex-col gap-4">
            <div class="flex items-center justify-center gap-4 mb-2">
                <span class="text-gruv-muted font-mono text-[10px] uppercase tracking-widest">abx.in // active_</span>
                <div class="pixel-pet scale-75"></div>
            </div>
            <h1 class="text-5xl sm:text-[9rem] font-black tracking-tightest leading-[0.85] sm:leading-[0.8] text-gruv-text">
                I build <span class="text-gruv-orange text-shadow-glow">invisible</span> systems.
            </h1>
        </div>

        <p class="text-lg sm:text-3xl text-gruv-muted leading-snug font-medium max-w-2xl tracking-tight px-4 sm:px-0">
            Hi, I'm <span class="text-gruv-text">Abinash Selvarasu</span>. I engineer high-stakes backend architecture and resilient payment workflows that handle the heavy lifting behind the scenes.
        </p>

        <div class="flex flex-col sm:flex-row gap-6 sm:gap-8 items-center mt-6">
            <a href="mailto:abinash@theabx.in" class="w-full sm:w-auto bg-gruv-orange text-gruv-bg px-8 sm:px-10 py-4 sm:py-5 rounded-full font-bold text-lg sm:text-xl hover:scale-105 transition-all duration-500 shadow-premium">
                Let's Work Together
            </a>
            <div class="flex items-center gap-8 sm:gap-6">
                <a href="https://github.com/AbiXnash" target="_blank" class="text-gruv-muted hover:text-gruv-text transition-colors">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                </a>
                <a href="https://linkedin.com" target="_blank" class="text-gruv-muted hover:text-gruv-text transition-colors">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                </a>
            </div>
        </div>
      </div>
    </section>

    <!-- Experience -->
    <section id="experience" class="flex flex-col gap-8 sm:gap-20 scroll-mt-32 reveal px-2 sm:px-0">
        <div class="flex flex-col gap-4">
            <h2 class="text-gruv-orange font-bold uppercase tracking-widest text-[10px] sm:text-sm">Experience</h2>
            <h3 class="text-4xl sm:text-6xl font-extrabold tracking-tighter">Where I've been.</h3>
        </div>
        <div class="flex flex-col gap-6 sm:gap-8">
            {work.items.map(item => (
                <ExperienceCard {...item} />
            ))}
        </div>
    </section>

    <!-- Projects -->
    <section id="projects" class="flex flex-col gap-8 sm:gap-20 scroll-mt-32 reveal px-2 sm:px-0">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 sm:gap-8">
            <div class="flex flex-col gap-4">
                <h2 class="text-gruv-orange font-bold uppercase tracking-widest text-[10px] sm:text-sm">Lab</h2>
                <h3 class="text-4xl sm:text-6xl font-extrabold tracking-tighter">What I've built.</h3>
            </div>
            <a href="https://github.com/AbiXnash" target="_blank" class="text-gruv-muted font-bold hover:text-gruv-orange transition-colors flex items-center gap-2 text-base sm:text-lg">
                Full Registry <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
        </div>
        
        <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8">
            {projects.items.map((item, index) => (
                <div class={`project-item ${index >= 4 ? 'hidden' : ''}`}>
                    <ProjectCard {...item} />
                </div>
            ))}
        </div>

        {projects.items.length > 4 && (
            <div class="flex justify-center mt-8">
                <button id="load-more-projects" class="px-8 py-3 rounded-full border border-gruv-border text-gruv-text font-bold hover:bg-gruv-surface transition-all flex items-center gap-2 group text-sm uppercase tracking-widest cursor-pointer">
                    Load More Artifacts
                    <svg class="group-hover:translate-y-1 transition-transform" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 13l5 5 5-5M7 6l5 5 5-5"/></svg>
                </button>
            </div>
        )}
    </section>

    <!-- Research -->
    <section id="research" class="flex flex-col gap-8 sm:gap-20 scroll-mt-32 reveal px-2 sm:px-0">
        <div class="flex flex-col gap-4">
            <h2 class="text-gruv-orange font-bold uppercase tracking-widest text-[10px] sm:text-sm">Notes</h2>
            <h3 class="text-4xl sm:text-6xl font-extrabold tracking-tighter">What I've learned.</h3>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {sortedResearch.map(item => (
                <div class="bg-gruv-surface/40 border border-gruv-border/30 rounded-[2rem] p-8 flex flex-col justify-between gap-6 hover:border-gruv-blue/50 transition-colors group">
                    <div class="flex flex-col gap-4">
                        <div class="text-gruv-blue font-bold text-[10px] uppercase tracking-widest opacity-60">Research Paper</div>
                        <h4 class="text-xl font-bold tracking-tight group-hover:text-gruv-blue transition-colors leading-tight">{item.title}</h4>
                        <p class="text-sm text-gruv-muted leading-relaxed line-clamp-3">{item.intro}</p>
                    </div>
                    <div class="flex items-center justify-between mt-4">
                        <span class="text-xs font-medium text-gruv-muted">{item.meta.split('·')[0].trim()}</span>
                        <a href={item.github} target="_blank" class="w-10 h-10 rounded-full bg-gruv-bg flex items-center justify-center text-gruv-muted hover:text-gruv-blue transition-colors">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- Education Replacement: Technical Arsenal -->
    <section class="flex flex-col gap-8 sm:gap-20 reveal mb-20 px-2 sm:px-0">
        <div class="flex flex-col gap-4 text-center items-center">
            <h2 class="text-gruv-orange font-bold uppercase tracking-widest text-[10px] sm:text-sm">Toolkit</h2>
            <h3 class="text-4xl sm:text-6xl font-extrabold tracking-tighter">My daily drivers.</h3>
        </div>
        <div class="max-w-4xl mx-auto w-full bg-gruv-surface/50 border border-gruv-border/30 rounded-apple p-10 sm:p-16 flex flex-col sm:flex-row items-center justify-between gap-10">
            <div class="flex flex-col gap-8 text-center sm:text-left flex-1">
                <div class="flex flex-col gap-2">
                    <div class="text-gruv-orange font-bold text-lg uppercase tracking-widest leading-none">Core Foundations</div>
                    <h4 class="text-3xl sm:text-4xl font-extrabold tracking-tighter">Java & Go Performance</h4>
                </div>
                <div class="flex flex-wrap justify-center sm:justify-start gap-3">
                    {['Spring Boot', 'PostgreSQL', 'Microservices', 'Distributed Systems', 'Astro', 'Bun', 'TypeScript'].map(tech => (
                        <span class="px-4 sm:px-5 py-2 sm:py-2.5 bg-gruv-bg rounded-xl font-mono text-[10px] sm:text-sm border border-gruv-border/50 text-gruv-muted hover:text-gruv-orange hover:border-gruv-orange transition-all duration-300 cursor-default">
                            {tech}
                        </span>
                    ))}
                </div>
            </div>
            <div class="w-24 h-24 sm:w-32 sm:h-32 bg-gruv-border/30 rounded-full flex items-center justify-center shrink-0 animate-pulse relative">
                <div class="absolute inset-0 bg-gruv-orange/20 blur-xl rounded-full"></div>
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gruv-orange relative z-10"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg>
            </div>
        </div>
    </section>

  </main>
</BaseLayout>

<script>
    function setupLoadMore() {
        const loadMoreBtn = document.getElementById('load-more-projects');
        const projectItems = document.querySelectorAll('.project-item');
        
        if (loadMoreBtn) {
            loadMoreBtn.addEventListener('click', () => {
                projectItems.forEach(item => item.classList.remove('hidden'));
                loadMoreBtn.parentElement?.remove();
            });
        }
    }

    // Initial setup
    setupLoadMore();

    // Re-setup on view transitions
    document.addEventListener('astro:after-swap', setupLoadMore);
</script>
